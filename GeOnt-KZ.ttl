###  http://ontogeo.kz/geont-kz#Acceptance_test
:Acceptance_test rdf:type owl:NamedIndividual .


###  http://ontogeo.kz/geont-kz#Acceptance_test_Concept
:Acceptance_test_Concept rdf:type owl:NamedIndividual ,
                                  ontolex:LexicalConcept ;
                         ontolex:isConceptOf :Acceptance_test ;
                         rdfs:comment "Load test on every installed anchor to verify compliance with acceptance criteria"@en ,
                                      "нагрузочное испытание каждого анкера для проверки соблюдения критерий приемки"@ru ,
                                      "Қабылдау критерийлерінің сақталуын тексеру үшін әрбір анкерге жүктемелік сынақ жүргізу."@kz ;
                         rdfs:isDefinedBy "СТ РК ЕN 1537-2011 Выполнение специальных геотехнических работ. Грунтовые анкеры (Document_86288b05-c9b3-406e-aa3f-86d5bdf17a4b)" ;
                         rdfs:label "acceptance test"@en ,
                                    "приемочное испытание"@ru ,
                                    "қабылдау сынағы"@kz .


###  http://ontogeo.kz/geont-kz#Acceptance_test_LexicalEntry
:Acceptance_test_LexicalEntry rdf:type owl:NamedIndividual ,
                                       ontolex:MultiWordExpression ;
                              ontolex:evokes :Acceptance_test_Concept ;
                              rdfs:label "acceptance test"@en ,
                                         "приемочное испытание"@ru ,
                                         "қабылдау сынағы"@kz .


###  http://ontogeo.kz/geont-kz#Accidental_actions
:Accidental_actions rdf:type owl:NamedIndividual .


###  http://ontogeo.kz/geont-kz#Accidental_actions_Concept
:Accidental_actions_Concept rdf:type owl:NamedIndividual ,
                                     ontolex:LexicalConcept ;
                            ontolex:isConceptOf :Accidental_actions ;
                            rdfs:comment "Temporary extreme actions with very low probability but severe consequences (seismic, blast, fire, collapse)"@en ,
                                         "Временные нагрузки и воздействия, возникающие в исключительных ситуациях, вероятность возникновения которых чрезвычайно мала, но последствия могут быть катастрофическими (сейсмические воздействия, нагрузки от взрыва и пожаров, воздействия от просадок грунта и т.п.)"@ru ,
                                         "Пайда болу ықтималдығы өте аз, бірақ салдары апатты болуы мүмкін ерекше жағдайларда туындайтын уақытша жүктемелер мен әсерлер (сейсмикалық әсерлер, жарылыс пен өрттен болатын жүктемелер, топырақтың шөгуінен болатын әсерлер және т.б.)."@kz ;
                            rdfs:isDefinedBy "НТП РК 08.05.1-2022 Проектирование оснований и фундаментов зданий и сооружений в сейсмических районах (Document_4a85e34a-20fa-49f7-bbc3-4aeca1ebd5d1)" ;
                            rdfs:label "accidental actions"@en ,
                                       "арнайы жүктемелер"@kz ,
                                       "особые нагрузки"@ru .


###  http://ontogeo.kz/geont-kz#Accidental_actions_LexicalEntry
:Accidental_actions_LexicalEntry rdf:type owl:NamedIndividual ,
                                          ontolex:MultiWordExpression ;
                                 ontolex:evokes :Accidental_actions_Concept ;
                                 rdfs:label "accidental actions"@en ,
                                            "арнайы жүктемелер"@kz ,
                                            "особые нагрузки"@ru .


###  http://ontogeo.kz/geont-kz#Action_load_effect
:Action_load_effect rdf:type owl:NamedIndividual .


###  http://ontogeo.kz/geont-kz#Action_load_effect_Concept
:Action_load_effect_Concept rdf:type owl:NamedIndividual ,
                                     ontolex:LexicalConcept ;
                            ontolex:isConceptOf :Action_load_effect ;
                            rdfs:comment "Forces or imposed deformations that produce internal stresses or displacements in a structure"@en ,
                                         "Конструкция элементтерінде кернеуді немесе олардың орын ауыстыруын тудыратын, конструкцияға тікелей түсірілген және «тікелей әсер» немесе «жүктеме» деп аталатын күштер."@kz ,
                                         "Силы, приложенные непосредственно к конструкции вызывающие в элементах конструкции напряжения, либо их перемещения, определяемые термином «воздействие непосредственное или прямое» или «нагрузка»"@ru ;
                            rdfs:isDefinedBy "НТП РК 07-01.6-2012 Общая устойчивость геотехнических сооружений (Document_96a2406a-8776-4641-a9fe-6c77ddc2cf3c)" ;
                            rdfs:label "action (load effect)"@en ,
                                       "воздействие"@ru ,
                                       "әсер ету"@kz .


###  http://ontogeo.kz/geont-kz#Action_load_effect_LexicalEntry
:Action_load_effect_LexicalEntry rdf:type owl:NamedIndividual ,
                                          ontolex:Word ;
                                 ontolex:evokes :Action_load_effect_Concept ;
                                 rdfs:label "action (load effect)"@en ,
                                            "воздействие"@ru ,
                                            "әсер ету"@kz .


###  http://ontogeo.kz/geont-kz#Active_earth_pressure
:Active_earth_pressure rdf:type owl:NamedIndividual .


###  http://ontogeo.kz/geont-kz#Active_earth_pressure_Concept
:Active_earth_pressure_Concept rdf:type owl:NamedIndividual ,
                                        ontolex:LexicalConcept ;
                               ontolex:isConceptOf :Active_earth_pressure ;
                               rdfs:comment "Minimum soil pressure mobilised when a retaining structure moves away from the backfill"@en ,
                                            "Минимальное значение давления грунта активизирующегося при перемещении подпорного сооружения в сторону от засыпки"@ru ,
                                            "Тірек құрылысының топырақ толтырудан кері қарай жылжуы кезінде пайда болатын топырақ қысымының ең аз мәні"@kz ;
                               rdfs:isDefinedBy "НТП РК 07-01.6-2012 Общая устойчивость геотехнических сооружений (Document_96a2406a-8776-4641-a9fe-6c77ddc2cf3c)" ;
                               rdfs:label "active earth pressure"@en ,
                                          "активное давление грунта"@ru ,
                                          "топырақтың белсенді қысымы"@kz .


###  http://ontogeo.kz/geont-kz#Active_earth_pressure_LexicalEntry
:Active_earth_pressure_LexicalEntry rdf:type owl:NamedIndividual ,
                                             ontolex:MultiWordExpression ;
                                    ontolex:evokes :Active_earth_pressure_Concept ;
                                    rdfs:label "active earth pressure"@en ,
                                               "активное давление грунта"@ru ,
                                               "топырақтың белсенді қысымы"@kz .


###  http://ontogeo.kz/geont-kz#Adhesive
:Adhesive rdf:type owl:NamedIndividual .


###  http://ontogeo.kz/geont-kz#Adhesive_Concept
:Adhesive_Concept rdf:type owl:NamedIndividual ,
                           ontolex:LexicalConcept ;
                  ontolex:isConceptOf :Adhesive ;
                  rdfs:comment "Thermosetting-resin bonding compound used to glue laminates or impregnate and bond continuous carbon- or glass-fiber fabrics to reinforced-concrete substrates"@en ,
                               "Клеящий состав из термореактивной смолы для наклейки ламинатов или пропитки и наклейки изделий из непрерывного углеродного или стеклянного волокна( холсты, сетки и другие тканые материалы) на основание железобетонной конструкции"@ru ,
                               "Темірбетон конструкциясының негізіне ламинаттарды жапсыруға немесе үздіксіз көміртекті немесе шыны талшықтан жасалған бұйымдарды (кеніптер, торлар және басқа да тоқыма материалдарды) сіңдіріп жапсыруға арналған термореактивті шайыр негізіндегі желімдеуіш құрам"@kz ;
                  rdfs:isDefinedBy "СП 164.1325800.2014 Усиление железобетонных конструкций композитными материалами. Правила проектирования (Document_f3a93e50-b23c-4e83-acca-84e08bf6191a)" ;
                  rdfs:label "adhesive"@en ,
                             "адгезив"@ru ,
                             "желім"@kz .


