                     "қазу кезінде кездесуі мүмкін кедергілерді жою, қойтастар мен қатты жыныстарды ұсату үшін немесе қатты грунт пен тау жыныстарын бұрғылау үшін қолданылатын ауыр болат аспап"@kz ;
        rdfs:label "chisel"@en ,
                   "долото"@ru ,
