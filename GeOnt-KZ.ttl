                                   ontolex:isConceptOf :Design_free_tendon_length ;
                                   rdfs:comment "Tendon length between jack and start of bonded zone determined by test"@en ,
                                                "анкерді сынау арқылы арматураны тарту домкратындағы созылатын элементтің бекіту нүктесі мен созылатын элементтегі нүкте арасындағы созылатын элементтің есептелген ұзындығы."@kz ,
                                                "путем испытания анкера рассчитанная длина растягивающего элемента между точкой крепления растягивающего элемента на домкрате натяжения арматуры и точкой на растягивающем элементе"@ru ;
                                   rdfs:isDefinedBy "СТ РК ЕN 1537-2011 Выполнение специальных геотехнических работ. Грунтовые анкеры (Document_86288b05-c9b3-406e-aa3f-86d5bdf17a4b)" ;
                                   rdfs:label "design free tendon length"@en ,
