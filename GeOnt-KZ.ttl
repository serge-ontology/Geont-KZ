###  http://ontogeo.kz/geont-kz#Microzoning_map_engineering_geology
:Microzoning_map_engineering_geology rdf:type owl:NamedIndividual .


###  http://ontogeo.kz/geont-kz#Microzoning_map_engineering_geology_Concept
:Microzoning_map_engineering_geology_Concept rdf:type owl:NamedIndividual ,
                                                      ontolex:LexicalConcept ;
                                             ontolex:isConceptOf :Microzoning_map_engineering_geology ;
                                             rdfs:comment "Map displaying engineering-geological factors affecting seismic response and construction"@en ,
                                                          "Отображение на топографической карте компонентов инженерно-геологической среды оказывающих влияние на сейсмичность рассматриваемой территории и способных повлиять на создание и использование зданий и сооружений"@ru ,
                                                          "Қарастырылып отырған аумақтың сейсмикалылығына әсер ететін және ғимараттар мен құрылыстарды салуға және пайдалануға ықпал ете алатын инженерлік-геологиялық ортаның компоненттерін топографиялық картада көрсету"@kz ;
                                             rdfs:isDefinedBy "НТП РК 08.05.1-2022 Проектирование оснований и фундаментов зданий и сооружений в сейсмических районах (Document_4a85e34a-20fa-49f7-bbc3-4aeca1ebd5d1)" ;
                                             rdfs:label "micro-zoning map (engineering geology)"@en ,
                                                        "инженерлік-геологиялық жағдайлар бойынша микроаймақтау картасы"@kz ,
                                                        "карта микрозонирования по инженерно-геологическим условиям"@ru .


###  http://ontogeo.kz/geont-kz#Microzoning_map_engineering_geology_LexicalEntry
:Microzoning_map_engineering_geology_LexicalEntry rdf:type owl:NamedIndividual ,
                                                           ontolex:MultiWordExpression ;
                                                  ontolex:evokes :Microzoning_map_engineering_geology_Concept ;
                                                  rdfs:label "micro-zoning map (engineering geology)"@en ,
                                                             "инженерлік-геологиялық жағдайлар бойынша микроаймақтау картасы"@kz ,
