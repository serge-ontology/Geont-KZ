###  http://ontogeo.kz/geont-kz#firm_stiff_loam
:firm_stiff_loam rdf:type owl:Class ;
                 owl:equivalentClass [ owl:intersectionOf ( :loam
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty :hasLiquidityIndex ;
                                                              owl:someValuesFrom [ rdf:type rdfs:Datatype ;
                                                                                   owl:onDatatype xsd:double ;
                                                                                   owl:withRestrictions ( [ xsd:minInclusive "0.25"^^xsd:double
                                                                                                          ]
                                                                                                        )
                                                                                 ]
                                                            ]
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty :hasLiquidityIndex ;
                                                              owl:someValuesFrom [ rdf:type rdfs:Datatype ;
                                                                                   owl:onDatatype xsd:double ;
                                                                                   owl:withRestrictions ( [ xsd:maxExclusive "0.5"^^xsd:double
                                                                                                          ]
                                                                                                        )
                                                                                 ]
                                                            ]
                                                          ) ;
                                       rdf:type owl:Class
                                     ] ;
                 rdfs:label "firm stiff loam"@en ,
                            "отқа төзімді саздауыт"@kk ,
                            "тугопластичный суглинок"@ru .


###  http://ontogeo.kz/geont-kz#loam
:loam rdf:type owl:Class ;
      rdfs:subClassOf :Cohesive_soil ;
      rdfs:comment "soil with a predominant concentration of clay and a high percentage of sand"@en-au ,
                   "грунт с преобладающей концентрацией глины и высоким процентом песка"@ru ,
                   "саздың басым концентрациясы және құмның жоғары пайызы бар топырақ"@kk ;
      rdfs:label "loam"@en ,
                 "саздауыт"@kk ,
                 "суглинок"@ru .


###  http://ontogeo.kz/geont-kz#sandy_loam
:sandy_loam rdf:type owl:Class ;
            rdfs:subClassOf :Cohesive_soil ;
            rdfs:comment "a loose sedimentary rock that consists predominantly of sand particles (about 80–90%) with the addition of 3–10% clay and dust impurities"@en ,
                         "негізінен құм бөлшектерінен (шамамен 80-90%) тұратын және 3-10% саз бен шаң қоспалары қосылған борпылдақ шөгінді тау жынысы"@kk ,
                         "рыхлая осадочная горная порода, которая состоит преимущественно из песчаных частиц (около 80–90%) с добавлением 3–10% глинистых и пылеватых примесей"@ru ;
            rdfs:label "sandy loam"@en ,
                       "супесь"@ru ,
                       "құмды саздауыт"@kk .


###  http://ontogeo.kz/geont-kz#stiff_loam
:stiff_loam rdf:type owl:Class ;
            owl:equivalentClass [ owl:intersectionOf ( :loam
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty :hasLiquidityIndex ;
                                                         owl:someValuesFrom [ rdf:type rdfs:Datatype ;
                                                                              owl:onDatatype xsd:double ;
                                                                              owl:withRestrictions ( [ xsd:minInclusive "0.0"^^xsd:double
                                                                                                     ]
                                                                                                   )
                                                                            ]
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty :hasLiquidityIndex ;
                                                         owl:someValuesFrom [ rdf:type rdfs:Datatype ;
                                                                              owl:onDatatype xsd:double ;
                                                                              owl:withRestrictions ( [ xsd:maxExclusive "0.25"^^xsd:double
                                                                                                     ]
                                                                                                   )
                                                                            ]
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
            rdfs:label "stiff loam"@en ,
                       "полутвердый суглинок"@ru ,
                       "қатты саздауыт"@kk .


###  http://ontogeo.kz/geont-kz#very_stiff_loam
:very_stiff_loam rdf:type owl:Class ;
                 owl:equivalentClass [ owl:intersectionOf ( :loam
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty :hasLiquidityIndex ;
                                                              owl:someValuesFrom [ rdf:type rdfs:Datatype ;
                                                                                   owl:onDatatype xsd:double ;
                                                                                   owl:withRestrictions ( [ xsd:maxExclusive "0.0"^^xsd:double
                                                                                                          ]
                                                                                                        )
                                                                                 ]
                                                            ]
                                                          ) ;
                                       rdf:type owl:Class
                                     ] ;
                 rdfs:label "very stiff loam"@en ,
                            "твердый суглинок"@ru ,
                            "өте қатты саздауыт"@kk .


#################################################################
#    Individuals
