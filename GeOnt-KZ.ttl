                                                  ontolex:LexicalConcept ;
                                         ontolex:isConceptOf :Thinelement_retaining_structure ;
                                         rdfs:comment "Slender retaining wall relying mainly on soil weight above base slab"@en ,
                                                      "Жұқа элементті қаттаушы құрылыс: тұрақтылығы негізінен іргетас плитасы үстіндегі топырақтың салмағымен және аз дәрежеде конструкцияның өз салмағымен қамтамасыз етілетін қаттаушы құрылыс"@kz ,
                                                      "Тонкоэлементное подпорное сооружение: Подпорное сооружение, устойчивость которого обеспечивается в основном весом грунта над фундаментной плитой и в небольшой степени собственным весом конструкции"@ru ;
                                         rdfs:isDefinedBy "НТП РК 07-01.6-2012 Общая устойчивость геотехнических сооружений (Document_96a2406a-8776-4641-a9fe-6c77ddc2cf3c)" ;
                                         rdfs:label "thin-element retaining structure"@en ,
                                                    "жұқа элементті тірек құрылымы"@kz ,
                                                    "тонкоэлементное подпорное сооружение"@ru .


