                                    ontolex:LexicalConcept ;
                           ontolex:isConceptOf :Hydraulicfill_dam ;
                           rdfs:comment "Embankment dam built > 50 % by hydraulic placement of sandy or clayey soils"@en ,
                                        "Денесі 50%-дан астам (көлемі бойынша) Гидромеханизация әдісімен сазды, құмды немесе құмды-қиыршық тасты топырақтардан тұрғызылатын бөгет"@kz ,
                                        "Плотина, тело которой более чем на 50 % (по объему) возводится из глинистых, песчаных или песчано-гравелистых грунтов методом гидромеханизации"@ru ;
                           rdfs:isDefinedBy "СП РК 3.04-105-2014 Плотины из грунтовых материалов (Document_347e1ac7-6a7c-458d-a054-19ce0a5c31f9)" ;
                           rdfs:label "hydraulic-fill dam"@en ,
                                      "Сумен шайылған топырақ бөгеті."@kz ,
                                      "земляная намывная плотина"@ru .


