                            rdfs:label "grout (bonding)"@en ,
                                       "раствор для запрессовки"@ru ,
                                       "сығымдау ерітіндісі"@kz .


###  http://ontogeo.kz/geont-kz#Grouting_cementation
:Grouting_cementation rdf:type owl:NamedIndividual .


###  http://ontogeo.kz/geont-kz#Grouting_cementation_Concept
:Grouting_cementation_Concept rdf:type owl:NamedIndividual ,
                                       ontolex:LexicalConcept ;
                              ontolex:isConceptOf :Grouting_cementation ;
                              rdfs:comment "Modification of soil properties by injecting cement-based slurries using injection, jet, or mixing methods"@en ,
                                           "Изменение физико-механических свойств грунтов с помощью цементных растворов, нагнетаемых в грунт по технологиям: инъекция, струйная или буросмесительная"@ru ,
                                           "Инъекция, ағынды немесе бұрғылап араластыру технологиялары бойынша топыраққа айдалатын цемент ерітінділерінің көмегімен топырақтардың физикалық-механикалық қасиеттерін өзгерту."@kz ;
                              rdfs:isDefinedBy "НТП РК 08.05.1-2022 Проектирование оснований и фундаментов зданий и сооружений в сейсмических районах (Document_4a85e34a-20fa-49f7-bbc3-4aeca1ebd5d1)" ;
                              rdfs:label "grouting (cementation)"@en ,
                                         "цементация"@ru ,
                                         "цементтеу"@kz .


