                                            ontolex:LexicalConcept ;
                                   ontolex:isConceptOf :Soilstructure_interaction ;
                                   rdfs:comment "Mutual influence between deformations in soil and the connected foundation or retaining structure"@en ,
                                                "Взаимное влияние деформаций в грунте и фундаменте или подпорной конструкции"@ru ,
                                                "Топырақ пен іргетастағы немесе тірек құрылысындағы деформациялардың өзара әсері"@kz ;
                                   rdfs:isDefinedBy "НТП РК 07-01.4-2012 (к СН РК EN СН РК EN 1997-1 20042011) Геотехническое проектирование. Часть. Основы геотехнического проектирования (Document_45246b43-b3ee-4544-9a94-1902464f16c4)" ;
                                   rdfs:label "soil–structure interaction"@en ,
                                              "взаимодействие грунта"@ru ,
                                              "топырақтың өзара әрекеттесуі"@kz .


