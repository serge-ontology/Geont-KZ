:Free_vibrations_Concept rdf:type owl:NamedIndividual ,
                                  ontolex:LexicalConcept ;
                         ontolex:isConceptOf :Free_vibrations ;
                         rdfs:comment "Oscillations occurring after a short-term excitation, without further external force"@en ,
                                      "Кенеттен түсірілген немесе қондырғының меншікті тербеліс периодымен салыстырғанда қысқа мерзімді (0,2Т-дан аспайтын, мұндағы Т - қондырғының меншікті тербеліс периоды) әсер ететін жүктемеден туындайтын тербелістер"@kz ,
                                      "Колебания, вызываемые внезапно приложенной нагрузкой или действующей кратковременно по сравнению с периодом собственных колебаний установки (не более 0,2Т, где Т- период собственных колебаний установки, с)"@ru ;
                         rdfs:isDefinedBy "СН РК 5.01-06-2013 Фундаменты машин с динамическими нагрузками (Document_ebb88a3e-397f-4a9a-992c-c0f29d49546c)" ;
                         rdfs:label "free vibrations"@en ,
                                    "колебания свободные"@ru ,
                                    "тербелістер бос"@kz .


