###  http://ontogeo.kz/geont-kz#Horizontal_displacement
:Horizontal_displacement rdf:type owl:NamedIndividual .


###  http://ontogeo.kz/geont-kz#Horizontal_displacement_Concept
:Horizontal_displacement_Concept rdf:type owl:NamedIndividual ,
                                          ontolex:LexicalConcept ;
                                 ontolex:isConceptOf :Horizontal_displacement ;
                                 rdfs:comment "Lateral movement of ground or a structure produced by differential settlement"@en ,
                                              "Горизонтальное перемещение грунта или здания и сооружения, возникающее при значительных неравномерных просадках на участках их изменения от минимальных до максимальных значений"@ru ,
                                              "Шөгудің ең аз мәнінен ең үлкен мәніне дейін өзгеретін учаскелердегі елеулі, біркелкі емес шөгулер кезінде пайда болатын топырақтың немесе ғимарат пен құрылыстың көлденең ығысуы"@kz ;
                                 rdfs:isDefinedBy "СН РК 2.03-01-2011 Здания и сооружения на подрабатываемых территориях и просадочных грунтах (Document_14719947-81c3-4bcd-917d-5b23915055e1)" ;
                                 rdfs:label "horizontal displacement"@en ,
                                            "горизонтальное перемещение"@ru ,
                                            "көлденең қозғалыс"@kz .


###  http://ontogeo.kz/geont-kz#Horizontal_displacement_LexicalEntry
:Horizontal_displacement_LexicalEntry rdf:type owl:NamedIndividual ,
                                               ontolex:MultiWordExpression ;
                                      ontolex:evokes :Horizontal_displacement_Concept ;
                                      rdfs:label "horizontal displacement"@en ,
                                                 "горизонтальное перемещение"@ru ,
                                                 "көлденең қозғалыс"@kz .


###  http://ontogeo.kz/geont-kz#Horizontal_ground_strain
:Horizontal_ground_strain rdf:type owl:NamedIndividual .


###  http://ontogeo.kz/geont-kz#Horizontal_ground_strain_Concept
:Horizontal_ground_strain_Concept rdf:type owl:NamedIndividual ,
                                           ontolex:LexicalConcept ;
                                  ontolex:isConceptOf :Horizontal_ground_strain ;
                                  rdfs:comment "Differential horizontal deformation (extension/compression) of ground surface"@en ,
                                               "Деформации земной поверхности( массива горных пород) в горизонтальной плоскости, вызванные неравномерностью горизонтальных сдвижений в мульде сдвижения (массиве горных пород)"@ru ,
                                               "Ығысу мульдасындағы (тау жыныстары массивіндегі) көлденең ығысулардың біркелкі болмауынан туындаған жер бетінің (тау жыныстары массивінің) көлденең жазықтықтағы деформациялары."@kz ;
                                  rdfs:isDefinedBy "СН РК 2.03-01-2011 Здания и сооружения на подрабатываемых территориях и просадочных грунтах (Document_14719947-81c3-4bcd-917d-5b23915055e1)" ;
                                  rdfs:label "horizontal ground strain"@en ,
                                             "жер бетінің созылуының немесе қысылуының салыстырмалы көлденең деформациясы"@kz ,
                                             "относительные горизонтальные деформации растяжения или сжатия земной поверхности"@ru .


