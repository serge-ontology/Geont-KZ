                                      rdfs:label "dynamic cone resistance"@en ,
                                                 "топырақтың шартты динамикалық кедергісі"@kz ,
                                                 "условное динамическое сопротивление грунта"@ru .


###  http://ontogeo.kz/geont-kz#Dynamic_liquefaction
:Dynamic_liquefaction rdf:type owl:NamedIndividual .


###  http://ontogeo.kz/geont-kz#Dynamic_liquefaction_Concept
:Dynamic_liquefaction_Concept rdf:type owl:NamedIndividual ,
                                       ontolex:LexicalConcept ;
                              ontolex:isConceptOf :Dynamic_liquefaction ;
                              rdfs:comment "Transformation of saturated soils to a fluid state due to structural breakdown under stress waves"@en ,
                                           "Переход водонасыщенных дисперсных грунтов в текучее состояние в результате разрушения структурных связей под действием волн напряжений разного типа"@ru ,
                                           "Әр түрлі типтегі кернеу толқындарының (мысалы, жер сілкінісі кезінде) әсерінен құрылымдық байланыстардың бұзылуы нәтижесінде сумен қаныққан дисперсті Топырақтардың сұйық күйге ауысуы"@kz ;
                              rdfs:isDefinedBy "СТ РК 2156-2-2011 Геотехнические исследования и испытания Идентификация и классификация грунтов. Часть 2. Принципы и классификация (Document_4a01341f-420d-4f8a-a08f-e72abc9955e4)" ;
                              rdfs:label "dynamic liquefaction"@en ,
                                         "динамикалық сұйылту"@kz ,
                                         "динамическое разжижение"@ru .


