                          ontolex:evokes :Guide_frame_Concept ;
                          rdfs:label "guide frame"@en ,
                                     "Орнату нұсқаулығы"@kz ,
                                     "направляющая установки"@ru .


###  http://ontogeo.kz/geont-kz#Hammer_cushion_helmet
:Hammer_cushion_helmet rdf:type owl:NamedIndividual .


