                            ontolex:LexicalConcept ;
                   ontolex:isConceptOf :Soil_mass ;
                   rdfs:comment "Volume of ground beneath or around a structure at least as large as the influence zone"@en ,
                                "Объем грунта, находящийся в основании здания/ сооружения или вмещающий его, размеры которого неменьше зоны влияния здания/ сооружения, или выделяемый для решения специальных задач"@ru ,
                                "Ғимараттың/құрылыстың негізінде орналасқан немесе оны сыйғызатын, мөлшері ғимараттың/құрылыстың әсер ету аймағынан кем емес, немесе арнайы есептерді шешу үшін бөлінетін топырақ көлемі."@kz ;
                   rdfs:isDefinedBy "ГОСТ 25100-2020 Грунты. Классификация (Document_e82f32ee-ecc7-4795-ad0b-963c3b9d8abd)" ;
                   rdfs:label "soil mass"@en ,
                              "массив грунта"@ru ,
                              "топырақ массиві"@kz .


