                                      ontolex:LexicalConcept ;
                             ontolex:isConceptOf :Collapsible_stratum ;
                             rdfs:comment "Thickness of collapsible soils above stable ground"@en ,
                                          "Слой грунта от природной поверхности или уровня планировки до кровли непросадочного грунта"@ru ,
                                          "Табиғи жер бетінен немесе жоспарлау деңгейінен шөкпейтін топырақтың жоғарғы жабынына дейінгі топырақ қабаты."@kz ;
                             rdfs:isDefinedBy "СН РК 2.03-01-2011 Здания и сооружения на подрабатываемых территориях и просадочных грунтах (Document_14719947-81c3-4bcd-917d-5b23915055e1)" ;
                             rdfs:label "collapsible stratum"@en ,
