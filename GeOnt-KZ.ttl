:Overburden_Concept rdf:type owl:NamedIndividual ,
                             ontolex:LexicalConcept ;
                    ontolex:isConceptOf :Overburden ;
                    rdfs:comment "Strata overlying an ore/body or deposit that must be removed and dumped during extraction"@en ,
                                 "Пайдалы қабаттың үстін жауып жатқан, оны өңдеу кезінде үйіндіге шығарылуға жататын геологиялық ортаның немесе (және) техногендік түзілімдердің бір бөлігі"@kz ,
                                 "Часть геологической среды или (и) техногенных образований, перекрывающая полезную толщу сверху, подлежащая удалению в отвалы при разработке"@ru ;
                    rdfs:isDefinedBy "СН РК 1.02-19-2007 Изыскания грунтовых строительных материалов. Общие правила выполнения работ (Document_0f135841-7e87-4c5e-aa37-c02f3a99eeb0)" ;
                    rdfs:label "overburden"@en ,
                               "аршылған жыныстар"@kz ,
                               "вскрышные породы"@ru .


