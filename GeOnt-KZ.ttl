                                 ontolex:LexicalConcept ;
                        ontolex:isConceptOf :Soil_shrinkage ;
                        rdfs:comment "Volume reduction due to change of soil structure (drying, cement loss)"@en ,
                                     "Топырақтың отыруы: құрылымдық байланыстар күйінің өзгеруі салдарынан болатын деформация түрі."@kz ,
                                     "Усадка грунта: вид деформации вследствии изменения состояния структурных связей"@ru ;
                        rdfs:isDefinedBy "НТП РК 07-01.5-2012 Геотехническое проектирование. Проектирование основании, усиленных химическими методами (Document_9b012e20-3a25-4361-a7d9-d4f90494249a)" ;
                        rdfs:label "soil shrinkage"@en ,
                                   "топырақтың шөгуі"@kz ,
                                   "усадка грунта"@ru .


