:Permanent_actions rdfs:comment "Actions acting throughout service life with negligible variation (e.g., self-weight)"@en ,
                                "Воздействие в течение всего срока эксплуатации, временное изменение величины которого, по сравнению со средним значением, очень незначительно, или при котором изменение до достижения определенного предельного значения происходит всегда водном направлении (равномерно)"@ru ,
                                "Пайдаланудың барлық мерзімі ішінде әсер ететін, шамасының орташа мәнмен салыстырғанда уақытша өзгеруі өте аз болатын немесе белгілі бір шекті мәнге жеткенге дейінгі өзгерісі әрдайым бір бағытта (біркелкі) жүретін әсер ету."@kz ;
                   rdfs:label "permanent actions"@en ,
                              "жүктемелер"@kz ,
                              "нагрузки"@ru .


:Permanent_anchor rdfs:comment "Ground anchor designed for a service life longer than two years"@en ,
                               "анкер с запланированным сроком службы более 2 лет"@ru ,
                               "жоспарланған қызмет мерзімі 2 жылдан асатын анкер"@kz ;
                  rdfs:label "permanent anchor"@en ,
                             "долговременный анкер"@ru ,
                             "ұзақ мерзімді анкер"@kz .


:Permanent_ground_anchor rdfs:comment "Anchor designed for the full service life of the structure it supports"@en ,
                                      "Грунтовый анкер с расчетным сроком, равным сроку эксплуатации удерживаемой конструкции"@ru ,
                                      "Есептік мерзімі ұсталатын конструкцияның пайдалану мерзіміне тең топырақты анкер."@kz ;
                         rdfs:label "permanent ground anchor"@en ,
                                    "постоянный анкер"@ru ,
                                    "тұрақты анкер"@kz .


:Permanent_loadaction rdfs:comment "Action present for the whole design life with negligible variation"@en ,
                                   "Воздействие в течение всего срока эксплуатации, временное изменение величины которого по сравнению со средним значением очень незначительно, или при котором изменение до достижения определенного предельного значения происходит всегда водном направлении (равномерно)"@ru ,
                                   "Пайдаланудың барлық мерзімі ішіндегі, шамасының уақытша өзгеруі орташа мәнмен салыстырғанда өте елеусіз болатын немесе белгілі бір шекті мәнге жеткенге дейінгі өзгерісі әрдайым бір бағытта (біркелкі) жүретін әсер."@kz ;
                      rdfs:label "permanent load/action"@en ,
                                 "постоянное воздействие"@ru ,
                                 "тұрақты әсер"@kz .


:Permeability rdfs:comment "Ability of soils to transmit water by seepage"@en ,
                           "Способность грунтов фильтровать воду"@ru ,
                           "Топырақтың суды сүзу қабілеті"@kz ;
              rdfs:label "permeability"@en ,
                         "водопроницаемость"@ru ,
                         "су өткізгіштігі"@kz .


:Permissible_foundation_deformations rdfs:comment "Foundation movements that cause only damage reparable without loss of serviceability"@en ,
                                                  "Деформации, способные вызвать такие повреждения в сооружениях, при которых для дальнейшей эксплуатации их по прямому назначению достаточно проведение текущих наладочных и ремонтных работ"@ru ,
                                                  "Ғимараттарды әрі қарай тікелей мақсаты бойынша пайдалану үшін ағымдағы жөндеу және реттеу жұмыстарын жүргізу жеткілікті болатын зақымдануларды тудыратын деформациялар"@kz ;
                                     rdfs:label "permissible foundation deformations"@en ,
                                                "деформации основания сооружений допустимые"@ru ,
                                                "Құрылыстар негіздерінің рұқсат етілген деформациялары."@kz .


:Pile rdfs:comment "Driven or cast-in-place element transferring load to soil"@en ,
                   "Жүктемені негізге беруге арналған, топыраққа батырылған немесе топырақта жасалған тік немесе көлбеу конструкция."@kz ,
                   "Погруженная в грунт или изготовленная в грунте вертикальная или наклонная конструкция, предназначенная для передачи нагрузки на основание"@ru ;
      rdfs:label "pile"@en ,
                 "свая"@ru ,
                 "қада"@kz .


:Pile_base_soil rdfs:comment "Ground mass that interacts with the pile shaft and toe to carry load"@en ,
                             "Часть массива грунта, воспринимающая нагрузку, передаваемую сваей, и взаимодействующая со сваей"@ru ,
                             "Қазық арқылы берілетін жүктемені қабылдайтын және қазықпен өзара әрекеттесетін топырақ массивінің бөлігі."@kz ;
                rdfs:label "pile base soil"@en ,
                           "основание сваи"@ru ,
                           "қаданың негізі"@kz .


:Pile_bearing_capacity rdfs:comment "Maximum load that a single pile can safely carry"@en ,
                                    "Максимальная нагрузка, которую можно допустить на одиночную сваю по грунту"@ru ,
                                    "Топырақ бойынша жеке қадаға түсіруге рұқсат етілген ең үлкен жүктеме."@kz ;
                       rdfs:label "pile bearing capacity"@en ,
                                  "несущая способность сваи"@ru ,
                                  "қаданың жүк көтергіштігі"@kz .


:Pile_cap rdfs:comment "Reinforced element distributing loads to a group of piles"@en ,
                       "Распределительная балка или плита, объединяющая головы свай и перераспределяющая на них нагрузку от вышерасположенных конструкций"@ru ,
                       "Қадалардың бастарын біріктіретін және жоғары орналасқан конструкциялардан түсетін жүктемені оларға қайта бөлетін таратушы арқалық немесе тақта."@kz ;
          rdfs:label "pile cap"@en ,
                     "ростверк"@kz ,
                     "ростверк"@ru .


:Pile_cluster rdfs:comment "Tightly spaced group of piles connected by a common cap to support a single column"@en ,
                           "Компактно размещаемая группа свай, объединенная ростверком и передающая нагрузку на основание, как правило, от одиночной колонны или опоры"@ru ,
                           "Әдетте, жеке колоннадан немесе тіректен негізге жүктеме беретін, ростверкпен біріктірілген, жинақы орналасқан қадалар тобы."@kz ;
              rdfs:label "pile cluster"@en ,
                         "куст свай"@ru ,
                         "қадалар шоғыры"@kz .


:Pile_group_mat rdfs:comment "Extensive array of piles connected by a common cap"@en ,
                             "Бағандар немесе тіректер жүйесінен негізге жүктемені беретін, ортақ ростверкпен біріктірілген қадалардың үлкен тобы."@kz ,
                             "большая группа свай, объединенная общим ростверком, передающая нагрузку на основание от системы колонн или опор"@ru ;
                rdfs:label "pile group (mat)"@en ,
                           "свайное поле"@ru ,
                           "қадалар алаңы"@kz .


:Piled_foundation rdfs:comment "Foundation system comprising piles and cap"@en ,
                               "Жүктемені негізге беретін біртұтас конструкцияға біріктірілген қадалар кешені."@kz ,
                               "Комплекс свай, объединенных в единую конструкцию, передающую нагрузку на основание"@ru ;
                  rdfs:label "piled foundation"@en ,
                             "свайный фундамент"@ru ,
                             "қадалы іргетас"@kz .


:Pipe_drain rdfs:comment "Buried perforated pipe draining groundwater"@en ,
                         "Трубчатая дрена: Подземный искусственный водоток для сбора и отвода грунтовых вод"@ru ,
                         "Түтікше дренаж: жер асты суларын жинау және бұру үшін арналған жер асты жасанды су ағысы"@kz ;
            rdfs:label "pipe drain"@en ,
                       "трубчатая дрена"@ru ,
                       "құбырлы дренаж"@kz .


:Planestress_state rdfs:comment "Stress condition where all significant stresses lie in a single plane"@en ,
                                "Дененің ішіндегі барлық кернеулер тек бір жазықтықта әсер ететін және сәйкес есеп екі өлшемді болатын күй."@kz ,
                                "состояние, когда все напряжения внутри тела действуют только водной плоскости и сответствующая задача становится двумерной"@ru ;
                   rdfs:label "plane-stress state"@en ,
                              "плоское напряженное состояние"@ru ,
                              "тегіс кернеу күйі"@kz .


:Plastic_frozen_soil rdfs:comment "Frozen soil cemented by ice, exhibiting viscoplastic behaviour under load"@en ,
                                  "Мұзбен цементтелген, тұтқыр-пластикалық қасиеттерге және сыртқы жүктеме әсерінен сығылғыштыққа ие дисперсті топырақ."@kz ,
                                  "дисперсный грунт, сцементированный льдом, обладающий вязко-пластичными свойствами и сжимаемостью под внешней нагрузкой"@ru ;
                     rdfs:label "plastic frozen soil"@en ,
                                "пластикалық мұздатылған топырақ"@kz ,
                                "пластичномерзлый грунт"@ru .


:Point_wetting_source rdfs:comment "Small wetting source whose plan dimensions are roughly equal"@en ,
                                   "Жер бетіндегі өлшемдерінің қатынасы 1,0-ге тең немесе жақын болатын топырақты сулаудың көзі"@kz ,
                                   "Источник замачивания грунта с отношением размеров в плане равным или близким к1,0"@ru ;
                      rdfs:label "point wetting source"@en ,
                                 "нүктелік сулау көзі"@kz ,
                                 "точечный источник замачивания"@ru .


:Pore_water_pressure rdfs:comment "Pressure of water within soil pores in excess of atmospheric"@en ,
                                  "Жүктеме әсерінен топырақтың тығыздалу процесінде оның кеуектеріндегі судың артық (атмосфералықтан жоғары) қысымы."@kz ,
                                  "Избыточное( сверх атмосферного) давление воды в порах грунта в процессе его консолидации под нагрузкой"@ru ;
                     rdfs:label "pore water pressure"@en ,
                                "кеуекті қысым"@kz ,
                                "поровое давление"@ru .


:Porepressure_ratio rdfs:comment "Ratio of maximum excess pore pressure to total vertical stress"@en ,
                                 "Максималды кеуектік қысымның топыраққа түсетін толық қысымға қатынасы"@kz ,
                                 "Отношение максимального порового давления к полному давлению на грунт"@ru ;
                    rdfs:label "pore-pressure ratio"@en ,
                               "кеуекті қысым коэффициенті"@kz ,
                               "коэффициент порового давления"@ru .


:Porosity rdfs:comment "Ratio of void volume to total volume of soil"@en ,
                       "свойство грунта, имеющего в своем составе пустоты, заполненные газом, воздухом или водой"@ru ,
                       "Құрамында газбен, ауамен немесе сумен толтырылған қуыстары бар топырақтың қасиеті."@kz ;
          rdfs:label "porosity"@en ,
                     "кеуектілік"@kz ,
                     "пористость"@ru .


:Preblasting_operation rdfs:comment "Drilling and blasting along panel line before slurry-wall excavation"@en ,
                                    "Предварительная операция, состоящая в пробуривании отверстий вдоль расположения поодной линии стен, бетонируемых в траншее для закладки взрывчатых веществ в высокопрочный материал и подрыва перед началом выемки грунта для стен, бетонируемых в траншее"@ru ,
                                    "Траншеяда бетондалатын қабырғаларға арналған топырақты қазып алуды бастамас бұрын, жоғары берікті материалға жарылғыш заттарды салу және жару үшін траншеяда бетондалатын қабырғалардың бір сызық бойымен орналасуында тесіктерді бұрғылаудан тұратын алдын ала операция."@kz ;
                       rdfs:label "pre-blasting operation"@en ,
                                  "жарылыс алдында орындалатын процесс"@kz ,
                                  "процесс выполняемый перед взрыванием"@ru .


:Predicted_displacements_and_deformations rdfs:comment "Estimated ground movements when mining schedule and necessary input data are known"@en ,
                                                       "Величины сдвижений и деформаций, определяемые в условиях, когда имеются календарные планы развития горных работ и известны необходимые для расчетов исходные данные"@ru ,
                                                       "Тау-кен жұмыстарын дамытудың күнтізбелік жоспарлары болған және есептеу үшін қажетті бастапқы деректер белгілі болған жағдайларда айқындалатын жылжулар мен деформациялардың шамалары"@kz ;
                                          rdfs:label "predicted displacements and deformations"@en ,
                                                     "деформации и сдвижения ожидаемые"@ru ,
                                                     "күтілімдегі деформациялар мен қозғалыстар"@kz .


:Pressure_diagram rdfs:comment "Plot showing pressure distribution on a retaining structure"@en ,
                               "Тіреу құрылысына түсетін қысым шамасының таралуын көрсететін графикалық кескін."@kz ,
                               "графическое отображение, показывающее распределение величины давления на подпорное сооружение"@ru ;
                  rdfs:label "pressure diagram"@en ,
                             "эпюра давления"@ru ,
                             "қысым диаграммасы"@kz .


:Primer rdfs:comment "Material applied to concrete surface to enhance adhesive bond"@en ,
                     "Адгезивті жақпас бұрын темірбетон конструкциясының негізін алдын ала дайындау үшін қолданылатын материал."@kz ,
                     "Материал, применяемый для предварительной подготовки основания железобетонной конструкции перед нанесением адгезива"@ru ;
        rdfs:label "primer"@en ,
                   "праймер"@kz ,
                   "праймер"@ru .


:Probabilistic_seismic_hazard_analysis rdfs:comment "Method that estimates the probability of ground-motion levels being exceeded during earthquakes"@en ,
                                                    "Жер сілкінісі кезінде топырақ қозғалысының нақты деңгейінен асып кету ықтималдығын анықтау әдісі"@kz ,
                                                    "Метод определения вероятности превышения конкретного уровня движения грунта при землетрясениях"@ru ;
                                       rdfs:label "probabilistic seismic hazard analysis"@en ,
                                                  "вероятностный анализ сейсмической опасности"@ru ,
                                                  "сейсмикалық қауіптің ықтималдық талдауы"@kz .


:Protective_pillar rdfs:comment "Portion of mineral left unmined to safeguard surface structures"@en ,
                                "Тау-кен қазбаларының объектілерге әсер ету қаупін болдырмау мақсатында жер қойнауында қалдырылатын пайдалы қазба кен орнының бөлігі."@kz ,
                                "часть залежи полезного ископаемого, оставляемая в недрах в целях предотвращения опасности влияния горных разработок на объекты"@ru ;
                   rdfs:label "protective pillar"@en ,
                              "толық қауіпсіздік"@kz ,
                              "целик предохранительный"@ru .


:Quasithixotropic_soils rdfs:comment "Cohesive soils with mainly coagulation structure that weaken under disturbance and regain strength at rest"@en ,
                                     "Динамикалық әсер кезінде беріктігін жоғалтатын және кейіннен көлемі мен ылғалдылығы өзгермеген жағдайда тыныштық күйде беріктігін қалпына келтіретін, басым көпшілігі коагуляциялық құрылымды байланысқан топырақтар, олардың негізінде құрылымдық байланыстар мен кеуектік кеңістіктің түрленуінің қосымша әсерлерімен күрделенген тиксотроптық құбылыстар жатыр"@kz ,
                                     "связные грунты с преимущественно коагуляционными структурами, проявляющие при динамическом воздействии разупрочнение и последующее восстановление прочности в покое при неизменных объеме и влажности, в основе которых лежат тиксотропные явления, осложненные дополнительными эффектами преобразования структурных связей и порового пространства"@ru ;
                        rdfs:label "quasi-thixotropic soils"@en ,
                                   "квазитиксотропные грунты"@ru ,
                                   "квазитиксотропты топырақтар"@kz .


:Quick_condition_susceptibility rdfs:comment "Propensity of certain silty/sandy soils to rapid liquefaction under low-intensity vibration"@en ,
                                             "Дилатантты-тиксотропты және кейбір квазитиксотропты топырақтардың динамикалық жүктеменің шамалы қарқындылығы кезінде жылдам сұйылу қабілеті, бұл олардың құрылымының ерекшеліктерімен (сәйкесінше, аралас және метастабильді коагуляциялық) байланысты."@kz ,
                                             "способность дилатантно-тиксотропных и некоторых квазитиксотропных грунтов к быстрому разжижению при небольшой интенсивности динамической нагрузки, связанная с особенностями их структуры (смешанной и метастабильной коагуляционной, соответственно)"@ru ;
                                rdfs:label "quick condition susceptibility"@en ,
                                           "жүзу"@kz ,
                                           "плывунность"@ru .


:Rc_substrate rdfs:comment "Concrete surface receiving externally bonded laminates or fabrics"@en ,
                           "Композиттік материалдармен сырттай арматуралау арқылы күшейту немесе қалпына келтіру кезінде үстіне ламинаттарды немесе үздіксіз көміртекті немесе шыны талшықтан жасалған бұйымдарды (кенептер, торлар және басқа да тоқыма материалдар) жапсыратын темірбетон конструкциясының беті."@kz ,
                           "Поверхность железобетонной конструкции, на которую наклеивают ламинаты или изделия из непрерывного углеродного или стеклянного волокна (холсты, сетки и другие тканые материалы) при ее усилении или восстановлении внешним армированием из композитных материалов"@ru ;
              rdfs:label "RC substrate"@en ,
                         "основание железобетонной конструкции"@ru ,
                         "темірбетон құрылымының негізі"@kz .


