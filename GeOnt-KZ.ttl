@prefix : <http://ontogeo.kz/geont-kz#> .
@prefix ifc: <http://www.buildingsmart-tech.org/ifcOWL/IFC4#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@base <http://ontogeo.kz/geont-kz#> .

[ rdf:type owl:Ontology ;
   owl:imports <http://www.w3.org/ns/lemon/ontolex> ,
               <https://raw.githubusercontent.com/openBIMstandards/ifcOWL/refs/heads/master/IFC4.owl> ,
               <https://www.inf.ufrgs.br/bdi/ontologies/geocore.owl>
 ] .

#################################################################
#    Object Properties
#################################################################

###  http://ontogeo.kz/geont-kz#contains
:contains rdf:type owl:ObjectProperty .


###  http://ontogeo.kz/geont-kz#determines
:determines rdf:type owl:ObjectProperty .


###  http://ontogeo.kz/geont-kz#hasAttribute
:hasAttribute rdf:type owl:ObjectProperty ;
              owl:inverseOf :isAttributeOf ;
              rdfs:domain :GeotechnicalObject ;
              rdfs:range :GeotechnicalProperty .


###  http://ontogeo.kz/geont-kz#hasBoundary
:hasBoundary rdf:type owl:ObjectProperty ;
             owl:inverseOf :isBoundaryOf ;
             rdfs:domain <https://www.inf.ufrgs.br/bdi/ontologies/GEOCORE_0000001> ;
             rdfs:range <https://www.inf.ufrgs.br/bdi/ontologies/GEOCORE_0000011> .


###  http://ontogeo.kz/geont-kz#hasComponent
:hasComponent rdf:type owl:ObjectProperty .


###  http://ontogeo.kz/geont-kz#hasConstituent
:hasConstituent rdf:type owl:ObjectProperty .


###  http://ontogeo.kz/geont-kz#hasFoundation
:hasFoundation rdf:type owl:ObjectProperty ;
               owl:inverseOf :isFoundationFor ;
               rdfs:domain :Structure ;
               rdfs:range :Foundation .


###  http://ontogeo.kz/geont-kz#hasGeologicalOrigin
:hasGeologicalOrigin rdf:type owl:ObjectProperty .


###  http://ontogeo.kz/geont-kz#hasInput
:hasInput rdf:type owl:ObjectProperty .


###  http://ontogeo.kz/geont-kz#hasLayer
:hasLayer rdf:type owl:ObjectProperty .


###  http://ontogeo.kz/geont-kz#hasMember
:hasMember rdf:type owl:ObjectProperty .


###  http://ontogeo.kz/geont-kz#hasOutput
:hasOutput rdf:type owl:ObjectProperty .


###  http://ontogeo.kz/geont-kz#hasPart
:hasPart rdf:type owl:ObjectProperty ;
         owl:inverseOf :isPartOf ;
         rdfs:domain :Structure ;
         rdfs:range :Structural_element .


###  http://ontogeo.kz/geont-kz#hasParticipant
:hasParticipant rdf:type owl:ObjectProperty .


###  http://ontogeo.kz/geont-kz#hasRequirement
:hasRequirement rdf:type owl:ObjectProperty .


###  http://ontogeo.kz/geont-kz#hasRockType
:hasRockType rdf:type owl:ObjectProperty .


###  http://ontogeo.kz/geont-kz#hasSoilType
:hasSoilType rdf:type owl:ObjectProperty .


###  http://ontogeo.kz/geont-kz#hasSource
:hasSource rdf:type owl:ObjectProperty .


###  http://ontogeo.kz/geont-kz#influences
:influences rdf:type owl:ObjectProperty .


###  http://ontogeo.kz/geont-kz#interactsWith
:interactsWith rdf:type owl:ObjectProperty .


###  http://ontogeo.kz/geont-kz#isAttributeOf
:isAttributeOf rdf:type owl:ObjectProperty ;
               rdfs:domain :GeotechnicalProperty ;
               rdfs:range :GeotechnicalObject .


###  http://ontogeo.kz/geont-kz#isBoundaryOf
:isBoundaryOf rdf:type owl:ObjectProperty ;
              rdfs:domain <https://www.inf.ufrgs.br/bdi/ontologies/GEOCORE_0000011> ;
              rdfs:range <https://www.inf.ufrgs.br/bdi/ontologies/GEOCORE_0000001> .


###  http://ontogeo.kz/geont-kz#isComponentOf
:isComponentOf rdf:type owl:ObjectProperty .


###  http://ontogeo.kz/geont-kz#isConstituentOf
:isConstituentOf rdf:type owl:ObjectProperty .


###  http://ontogeo.kz/geont-kz#isContainedIn
:isContainedIn rdf:type owl:ObjectProperty .


###  http://ontogeo.kz/geont-kz#isDeterminedBy
:isDeterminedBy rdf:type owl:ObjectProperty .


###  http://ontogeo.kz/geont-kz#isFoundationFor
:isFoundationFor rdf:type owl:ObjectProperty ;
                 rdfs:domain :Foundation ;
                 rdfs:range :Structure .


###  http://ontogeo.kz/geont-kz#isInfluencedBy
:isInfluencedBy rdf:type owl:ObjectProperty .


###  http://ontogeo.kz/geont-kz#isInputTo
:isInputTo rdf:type owl:ObjectProperty .


###  http://ontogeo.kz/geont-kz#isLayerOf
:isLayerOf rdf:type owl:ObjectProperty .


###  http://ontogeo.kz/geont-kz#isMeasuredBy
:isMeasuredBy rdf:type owl:ObjectProperty .


###  http://ontogeo.kz/geont-kz#isMemberOf
:isMemberOf rdf:type owl:ObjectProperty .


###  http://ontogeo.kz/geont-kz#isOutputOf
:isOutputOf rdf:type owl:ObjectProperty .


###  http://ontogeo.kz/geont-kz#isPartOf
:isPartOf rdf:type owl:ObjectProperty ;
          rdfs:domain :Structural_element ;
          rdfs:range :Structure .


###  http://ontogeo.kz/geont-kz#isParticipantIn
:isParticipantIn rdf:type owl:ObjectProperty .


###  http://ontogeo.kz/geont-kz#isRequirementFor
:isRequirementFor rdf:type owl:ObjectProperty .


#################################################################
#    Data properties
#################################################################

###  http://ontogeo.kz/geont-kz#hasCarbonateContent
:hasCarbonateContent rdf:type owl:DatatypeProperty .


###  http://ontogeo.kz/geont-kz#hasChlorideContent
:hasChlorideContent rdf:type owl:DatatypeProperty .


###  http://ontogeo.kz/geont-kz#hasCohesion
:hasCohesion rdf:type owl:DatatypeProperty .


###  http://ontogeo.kz/geont-kz#hasCompressiveStrength
:hasCompressiveStrength rdf:type owl:DatatypeProperty .


###  http://ontogeo.kz/geont-kz#hasDensity
:hasDensity rdf:type owl:DatatypeProperty .


###  http://ontogeo.kz/geont-kz#hasFrictionAngle
:hasFrictionAngle rdf:type owl:DatatypeProperty .


###  http://ontogeo.kz/geont-kz#hasIceContent
:hasIceContent rdf:type owl:DatatypeProperty .


###  http://ontogeo.kz/geont-kz#hasLiquidLimit
:hasLiquidLimit rdf:type owl:DatatypeProperty .


###  http://ontogeo.kz/geont-kz#hasLiquidityIndex
:hasLiquidityIndex rdf:type owl:DatatypeProperty ;
                   rdfs:comment "a physical characteristic of clay soils that determines their consistency depending on moisture content"@en ,
                                "физическая характеристика глинистых грунтов, определяющая их консистенцию в зависимости от влажности"@ru ;
                   rdfs:label "liquidity coefficient"@en ,
                              "коэффициент текучести"@ru ,
                              "сазды топырақтардың ылғалдылық деңгейіне байланысты консистенциясын анықтайтын физикалық сипаттамасы"@kk ,
                              "сұйықтық коэффициенті"@kk .


###  http://ontogeo.kz/geont-kz#hasMoistureLimit
:hasMoistureLimit rdf:type owl:DatatypeProperty .


###  http://ontogeo.kz/geont-kz#hasOrganicContent
:hasOrganicContent rdf:type owl:DatatypeProperty .


###  http://ontogeo.kz/geont-kz#hasPermeability
:hasPermeability rdf:type owl:DatatypeProperty .


###  http://ontogeo.kz/geont-kz#hasPhValue
:hasPhValue rdf:type owl:DatatypeProperty .


###  http://ontogeo.kz/geont-kz#hasPlasticLimit
:hasPlasticLimit rdf:type owl:DatatypeProperty .


###  http://ontogeo.kz/geont-kz#hasPlasticityIndex
:hasPlasticityIndex rdf:type owl:DatatypeProperty .


###  http://ontogeo.kz/geont-kz#hasPoissonRatio
:hasPoissonRatio rdf:type owl:DatatypeProperty .


###  http://ontogeo.kz/geont-kz#hasPorosity
:hasPorosity rdf:type owl:DatatypeProperty ;
             rdfs:comment "the proportion of the volume of all pores contained in the soil in relation to its total volume"@en ,
                          "доля объема всех пор, содержащихся в грунте, по отношению к его общему объему"@ru ,
                          "топырақтағы барлық кеуектердің көлемінің оның жалпы көлеміне қатынасы"@kk ;
             rdfs:label "porosity"@en ,
                        "кеуектілік"@kk ,
                        "пористость"@ru .


###  http://ontogeo.kz/geont-kz#hasPorosityCoefficient
:hasPorosityCoefficient rdf:type owl:DatatypeProperty ;
                        rdfs:comment "the ratio of the volume of all pores in the soil to the volume of its solid particles"@en ,
                                     "отношение объема всех пор в грунте к объему его твердых частиц"@ru ,
                                     "топырақтағы барлық кеуектердің көлемінің оның қатты бөлшектерінің көлеміне қатынасы"@kk ;
                        rdfs:label "porosity coefficient"@en ,
                                   "кеуектілік коэффициенті"@kk ,
                                   "коэффициент пористости"@ru .


###  http://ontogeo.kz/geont-kz#hasShearStrength
:hasShearStrength rdf:type owl:DatatypeProperty .


###  http://ontogeo.kz/geont-kz#hasShrinkageLimit
:hasShrinkageLimit rdf:type owl:DatatypeProperty .


###  http://ontogeo.kz/geont-kz#hasStratigraphicPosition
:hasStratigraphicPosition rdf:type owl:DatatypeProperty .


###  http://ontogeo.kz/geont-kz#hasSulphateContent
:hasSulphateContent rdf:type owl:DatatypeProperty .


###  http://ontogeo.kz/geont-kz#hasUnitWeight
:hasUnitWeight rdf:type owl:DatatypeProperty .


###  http://ontogeo.kz/geont-kz#hasVoidRatio
:hasVoidRatio rdf:type owl:DatatypeProperty .


###  http://ontogeo.kz/geont-kz#hasWaterContent
:hasWaterContent rdf:type owl:DatatypeProperty .


###  http://ontogeo.kz/geont-kz#hasYoungsModulus
:hasYoungsModulus rdf:type owl:DatatypeProperty .


###  http://ontogeo.kz/geont-kz#measuresProperty
:measuresProperty rdf:type owl:DatatypeProperty .


#################################################################
#    Classes
#################################################################

###  http://ontogeo.kz/geont-kz#Acceptance_test
:Acceptance_test rdf:type owl:Class ;
                 rdfs:subClassOf :Investigative_test .


###  http://ontogeo.kz/geont-kz#Accidental_actions
:Accidental_actions rdf:type owl:Class ;
                    rdfs:subClassOf :Ultimate_limit_states .


###  http://ontogeo.kz/geont-kz#Action_load_effect
:Action_load_effect rdf:type owl:Class ;
                    rdfs:subClassOf :Seismic_action .


###  http://ontogeo.kz/geont-kz#Active_earth_pressure
:Active_earth_pressure rdf:type owl:Class ;
                       rdfs:subClassOf :Shear_strength ,
                                       ifc:IfcStructuralLoadStatic .


###  http://ontogeo.kz/geont-kz#Adhesive
:Adhesive rdf:type owl:Class ;
          rdfs:subClassOf :GeotechnicalObject ,
                          ifc:IfcMaterial .


###  http://ontogeo.kz/geont-kz#Airlift_pump
:Airlift_pump rdf:type owl:Class ;
              rdfs:subClassOf :GeotechnicalMethod .


###  http://ontogeo.kz/geont-kz#Allowable_load_loss
:Allowable_load_loss rdf:type owl:Class ;
                     rdfs:subClassOf :Limit_states .


###  http://ontogeo.kz/geont-kz#Amplitude_of_oscillations
:Amplitude_of_oscillations rdf:type owl:Class ;
                           rdfs:subClassOf :Deviation .


###  http://ontogeo.kz/geont-kz#Analysis_model
:Analysis_model rdf:type owl:Class ;
                rdfs:subClassOf :GeotechnicalObject .


###  http://ontogeo.kz/geont-kz#Anchor_bond_root
:Anchor_bond_root rdf:type owl:Class ;
                  rdfs:subClassOf :Ground_anchor .


###  http://ontogeo.kz/geont-kz#Anchor_head
:Anchor_head rdf:type owl:Class ;
             rdfs:subClassOf :Ground_anchor .


###  http://ontogeo.kz/geont-kz#Anchor_head_assembly
:Anchor_head_assembly rdf:type owl:Class ;
                      rdfs:subClassOf :Ground_anchor .


###  http://ontogeo.kz/geont-kz#Anchor_pullout_resistance
:Anchor_pullout_resistance rdf:type owl:Class ;
                           rdfs:subClassOf :Investigative_test .


###  http://ontogeo.kz/geont-kz#Angle_of_internal_friction
:Angle_of_internal_friction rdf:type owl:Class ;
                            rdfs:subClassOf :Soil_strength_parameters .


###  http://ontogeo.kz/geont-kz#Anisotropic_material
:Anisotropic_material rdf:type owl:Class ;
                      rdfs:subClassOf :Anisotropy ,
                                      ifc:IfcMaterial ,
                                      <https://www.inf.ufrgs.br/bdi/ontologies/GEOCORE_0000006> .


###  http://ontogeo.kz/geont-kz#Anisotropy
:Anisotropy rdf:type owl:Class ;
            rdfs:subClassOf :Stiffness .


###  http://ontogeo.kz/geont-kz#Anthropogenic_fill
:Anthropogenic_fill rdf:type owl:Class ;
                    rdfs:subClassOf :Anthropogenic_soil .


###  http://ontogeo.kz/geont-kz#Anthropogenic_soil
:Anthropogenic_soil rdf:type owl:Class ;
                    rdfs:subClassOf :Soil_ground .


###  http://ontogeo.kz/geont-kz#Anticorrosion_coating
:Anticorrosion_coating rdf:type owl:Class ;
                       rdfs:subClassOf :GeotechnicalObject .


###  http://ontogeo.kz/geont-kz#Antiseismic_measures
:Antiseismic_measures rdf:type owl:Class ;
                      rdfs:subClassOf :Seismic_resistance .


###  http://ontogeo.kz/geont-kz#Aquifer
:Aquifer rdf:type owl:Class ;
         rdfs:subClassOf :Overburden .


