###  http://ontogeo.kz/geont-kz#Firstorder_elasticperfectly_plastic_analysis
:Firstorder_elasticperfectly_plastic_analysis rdf:type owl:NamedIndividual .


###  http://ontogeo.kz/geont-kz#Firstorder_elasticperfectly_plastic_analysis_Concept
:Firstorder_elasticperfectly_plastic_analysis_Concept rdf:type owl:NamedIndividual ,
                                                               ontolex:LexicalConcept ;
                                                      ontolex:isConceptOf :Firstorder_elasticperfectly_plastic_analysis ;
                                                      rdfs:comment "1-ші ретті теория бойынша серпімді-идеалды-пластикалық есеп (first order elastic_perfectly plastic analysis): беріктік және деформациялану параметрлерін қайта нақтылаусыз (арттырусыз), сызықты-серпімді бөлігі және одан кейінгі идеалды-пластикалық бөлігі бар құрылыс материалдарының деформациялану заңдарының біріне және деформацияланбаған көтергіш конструкцияның геометриясына негізделген есеп."@kz ,
                                                                   "Analysis on undeformed geometry with linear elastic then perfectly plastic material law"@en ,
                                                                   "Упруго_идеально_пластичный расчет по теории1 порядка( first order elastic _ perfectly plastic analysis): Расчет на основе геометрии недеформированной несущей конструкции иодного из законов деформирования строительных материалов с линейно_эластичной частью и последующей идеально_пластичной частью без повторного уточнения( увеличения) параметров прочности и деформативности"@ru ;
                                                      rdfs:isDefinedBy "НТП РК 07-01.4-2012 (к СН РК EN СН РК EN 1997-1 20042011) Геотехническое проектирование. Часть. Основы геотехнического проектирования (Document_45246b43-b3ee-4544-9a94-1902464f16c4)" ;
                                                      rdfs:label "first-order elastic–perfectly plastic analysis"@en ,
                                                                 "Реттілік теориясы бойынша серпімді-идеалды-пластикалық есеп"@kz ,
                                                                 "упруго-идеально-пластичный расчет по теории порядка"@ru .


###  http://ontogeo.kz/geont-kz#Firstorder_elasticperfectly_plastic_analysis_LexicalEntry
:Firstorder_elasticperfectly_plastic_analysis_LexicalEntry rdf:type owl:NamedIndividual ,
                                                                    ontolex:MultiWordExpression ;
                                                           ontolex:evokes :Firstorder_elasticperfectly_plastic_analysis_Concept ;
                                                           rdfs:label "first-order elastic–perfectly plastic analysis"@en ,
                                                                      "Реттілік теориясы бойынша серпімді-идеалды-пластикалық есеп"@kz ,
                                                                      "упруго-идеально-пластичный расчет по теории порядка"@ru .


###  http://ontogeo.kz/geont-kz#Firstorder_nonlinear_analysis
:Firstorder_nonlinear_analysis rdf:type owl:NamedIndividual .


###  http://ontogeo.kz/geont-kz#Firstorder_nonlinear_analysis_Concept
:Firstorder_nonlinear_analysis_Concept rdf:type owl:NamedIndividual ,
                                                ontolex:LexicalConcept ;
                                       ontolex:isConceptOf :Firstorder_nonlinear_analysis ;
                                       rdfs:comment "Structural analysis using undeformed geometry but nonlinear material behaviour"@en ,
                                                    "Расчет на основе геометрии недеформированной несущей конструкции с учетом нелинейности показателей строительных материалов"@ru ,
                                                    "Құрылыс материалдарының көрсеткіштерінің сызықтық еместігін ескере отырып, деформацияланбаған көтергіш конструкцияның геометриясы негізіндегі есеп."@kz ;
                                       rdfs:isDefinedBy "НТП_РК_07_01_4_2012_к_СН_РК_EN_СН_РК_EN_1997_1_20042011_Геотехническое (Document_3d37a86c-6e58-405f-bb44-db4a878c9131)" ;
                                       rdfs:label "1 ретті теория бойынша сызықтық емес есептеу"@kz ,
                                                  "first-order nonlinear analysis"@en ,
                                                  "нелинейный расчет по теории 1 порядка"@ru .


