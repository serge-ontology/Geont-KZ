:Syngenetic_permafrost_Concept rdf:type owl:NamedIndividual ,
                                        ontolex:LexicalConcept ;
                               ontolex:isConceptOf :Syngenetic_permafrost ;
                               rdfs:comment "Frozen soil whose ice bonds formed concurrently with sediment deposition"@en ,
                                            "Тоңазыған кезде топырақтың қалыптасуымен бір мезгілде криогендік құрылымдық байланыстары қалыптасқан топырақ."@kz ,
                                            "грунт, криогенные структурные связи которого сформировались одновременно с образованием грунта при его промерзании"@ru ;
                               rdfs:isDefinedBy "СТ РК 2156-2-2011 Геотехнические исследования и испытания Идентификация и классификация грунтов. Часть 2. Принципы и классификация (Document_4a01341f-420d-4f8a-a08f-e72abc9955e4)" ;
                               rdfs:label "syngenetic permafrost"@en ,
                                          "сингенетикалық мұздатылған топырақ"@kz ,
                                          "сингенетически промерзший грунт"@ru .


