                                             ontolex:LexicalConcept ;
                                    ontolex:isConceptOf :Ground_steps_strata_breaks ;
                                    rdfs:comment "Concentrated ground surface offsets manifested as shear fractures"@en ,
                                                 "Сосредоточенные деформации земной поверхности, проявляющиеся в образовании трещин со сдвигом горных пород"@ru ,
                                                 "Тау жыныстарының ығысуымен бірге жарықшақтардың пайда болуымен білінетін жер бетінің шоғырланған деформациялары."@kz ;
                                    rdfs:isDefinedBy "11" ;
                                    rdfs:label "ground steps (strata breaks)"@en ,
                                               "Жоталар"@kz ,
                                               "Уступы"@ru .


