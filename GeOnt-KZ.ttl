:Sealing_grout_Concept rdf:type owl:NamedIndividual ,
                                ontolex:LexicalConcept ;
                       ontolex:isConceptOf :Sealing_grout ;
                       rdfs:comment "Hardening slurry used to solidify loose soils or fill voids"@en ,
                                    "Байланыссыз топырақтарды бекітуге, қуыстар мен жарықшақты жыныстарды тығыздауға қолданылатын байланыстырғыш негізіндегі қатаятын сулы ерітінді."@kz ,
                                    "Твердеющий водный раствор на основе вяжущего, применяемый для закрепления несвязных грунтов, уплотнения пустот и трещиноватых пород"@ru ;
                       rdfs:isDefinedBy "СН РК 5.01-01-2013 Земляные сооружения, основания и фундаменты (Document_97057d47-3060-42cc-bc25-2af554423c81)" ;
                       rdfs:label "sealing grout"@en ,
                                  "тампонаж ерітіндісі"@kz ,
                                  "тампонажный раствор"@ru .


