                                    ontolex:LexicalConcept ;
                           ontolex:isConceptOf :Soil_fluidisation ;
                           rdfs:comment "Generic term for soil becoming flowable regardless of cause"@en ,
                                        "Мұндай трансформацияның себебіне және кейінгі деформациялардың шамасына қарамастан топырақтың аққыш күйге өтуі."@kz ,
                                        "переход грунта в текучее состояние вне зависимости от причины такой трансформации и величины последующих деформаций"@ru ;
                           rdfs:isDefinedBy "СТ РК 2156-2-2011 Геотехнические исследования и испытания Идентификация и классификация грунтов. Часть 2. Принципы и классификация (Document_4a01341f-420d-4f8a-a08f-e72abc9955e4)" ;
                           rdfs:label "soil fluidisation"@en ,
