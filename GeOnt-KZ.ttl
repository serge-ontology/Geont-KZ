###  http://ontogeo.kz/geont-kz#Compaction_to_refusal
:Compaction_to_refusal rdf:type owl:NamedIndividual .


###  http://ontogeo.kz/geont-kz#Compaction_to_refusal_Concept
:Compaction_to_refusal_Concept rdf:type owl:NamedIndividual ,
                                        ontolex:LexicalConcept ;
                               ontolex:isConceptOf :Compaction_to_refusal ;
                               rdfs:comment "Tamping until no further surface drop occurs"@en ,
                                            "Бас тартқанға дейін тығыздау - беттің төмендеуі іс жүзінде байқалмайтын, яғни бас өзгеріс әкелмейтін соққылар санымен топырақты тығыздау."@kz ,
                                            "уплотнение до отказа- уплотнение грунта таким числом ударов, при котором практически отсутствует понижение поверхности, т.е. наблюдается отказ"@ru ;
                               rdfs:isDefinedBy "Пособие к СНиП 3.02.01-83 по производству работ при устройстве оснований и фундаментов (Document_e45ef66c-3a0d-4faa-b3af-5a1c40e29af6)" ;
                               rdfs:label "compaction to refusal"@en ,
                                          "уплотнение до отказа"@ru ,
                                          "істен шыққанға дейін тығыздау"@kz .


