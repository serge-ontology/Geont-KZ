                                 ontolex:LexicalConcept ;
                        ontolex:isConceptOf :Tamping_regime ;
                        rdfs:comment "Schedule of drop height or blow count during dynamic compaction"@en ,
                                     "Порядок изменения высоты сбрасывания трамбовки по мере нанесения ударов по грунту котлована, представляемый часто в графическом виде"@ru ,
                                     "Шұңқыр топырағына соққы беру барысында тығыздағышты түсіру биіктігінің өзгеру тәртібі, көбінесе графикалық түрде ұсынылады."@kz ;
                        rdfs:isDefinedBy "СП РК 5.01-107-2013 Контроль несущей способности фундаментов (ФВК) по результатам вытрамбовывания их котлованов (Document_6df2c6f6-ffd9-43e9-9120-5084265388ff)" ;
                        rdfs:label "tamping regime"@en ,
                                   "режим приложения ударной нагрузки"@ru ,
                                   "соққы жүктемесін қолдану режимі"@kz .


