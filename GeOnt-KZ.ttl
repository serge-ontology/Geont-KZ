                                                 ontolex:LexicalConcept ;
                                        ontolex:isConceptOf :Secondorder_nonlinear_analysis ;
                                        rdfs:comment "Analysis accounting for deformed geometry and nonlinear material response"@en ,
                                                     "Расчет на основе геометрии деформированной несущей конструкции с учетом нелинейности показателей строительных материалов"@ru ,
                                                     "Құрылыс материалдарының көрсеткіштерінің сызықтық еместігін ескере отырып, деформацияланған көтергіш конструкцияның геометриясы негізіндегі есеп."@kz ;
                                        rdfs:isDefinedBy "НТП РК 07-01.4-2012 (к СН РК EN СН РК EN 1997-1 20042011) Геотехническое проектирование. Часть. Основы геотехнического проектирования (Document_45246b43-b3ee-4544-9a94-1902464f16c4)" ;
                                        rdfs:label "2 ретті теория бойынша сызықтық емес есептеу"@kz ,
                                                   "second-order nonlinear analysis"@en ,
                                                   "нелинейный расчет по теории 2 порядка"@ru .


