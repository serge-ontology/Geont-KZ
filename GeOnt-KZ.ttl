:Undermined_development_Concept rdf:type owl:NamedIndividual ,
                                         ontolex:LexicalConcept ;
                                ontolex:isConceptOf :Undermined_development ;
                                rdfs:comment "Existing structures located above areas affected by underground mining"@en ,
                                             "Существующие здания, сооружения и инженерные коммуникации, расположенные на подрабатываемых территориях"@ru ,
                                             "Өңделетін аумақтарда орналасқан қолданыстағы ғимараттар, құрылыстар және инженерлік коммуникациялар."@kz ;
                                rdfs:isDefinedBy "СН РК 2.03-01-2011 Здания и сооружения на подрабатываемых территориях и просадочных грунтах (Document_14719947-81c3-4bcd-917d-5b23915055e1)" ;
                                rdfs:label "undermined development"@en ,
                                           "жұмыс істейтін құрылыс"@kz ,
                                           "подрабатываемая застройка"@ru .


