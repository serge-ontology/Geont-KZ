                                                ontolex:MultiWordExpression ;
                                       ontolex:evokes :Undermining_of_structure_Concept ;
                                       rdfs:label "undermining of structure"@en ,
                                                  "объектіні қосымша өңдеу"@kz ,
                                                  "подработка объекта"@ru .


###  http://ontogeo.kz/geont-kz#Upstream_blanket_cutoff
:Upstream_blanket_cutoff rdf:type owl:NamedIndividual .


###  http://ontogeo.kz/geont-kz#Upstream_blanket_cutoff_Concept
:Upstream_blanket_cutoff_Concept rdf:type owl:NamedIndividual ,
                                          ontolex:LexicalConcept ;
                                 ontolex:isConceptOf :Upstream_blanket_cutoff ;
                                 rdfs:comment "Low-permeability horizontal layer extending seepage path beneath a dam"@en ,
                                              "Бөгет экранына немесе ядросына жанасып орналасқан, су өткізгіштігі төмен топырақтардан жасалған және негіз топырағындағы бөгет астындағы сүзілу ағынының жолын ұзартуға арналған көлденең сүзілуге қарсы құрылғы."@kz ,
                                              "Горизонтальное противофильтрационное устройство, примыкающее к экрану или ядру плотины, устраиваемое из маловодопроницаемых грунтов и предназначенное для удлинения пути фильтрационного потока под плотиной в грунте основания"@ru ;
                                 rdfs:isDefinedBy "СП РК 3.04-105-2014 Плотины из грунтовых материалов (Document_347e1ac7-6a7c-458d-a054-19ce0a5c31f9)" ;
                                 rdfs:label "upstream blanket (cut-off)"@en ,
                                            "понур бөгеттері"@kz ,
                                            "понур плотины"@ru .


###  http://ontogeo.kz/geont-kz#Upstream_blanket_cutoff_LexicalEntry
:Upstream_blanket_cutoff_LexicalEntry rdf:type owl:NamedIndividual ,
                                               ontolex:MultiWordExpression ;
                                      ontolex:evokes :Upstream_blanket_cutoff_Concept ;
                                      rdfs:label "upstream blanket (cut-off)"@en ,
                                                 "понур бөгеттері"@kz ,
                                                 "понур плотины"@ru .


###  http://ontogeo.kz/geont-kz#Upstream_face_impervious_blanket
:Upstream_face_impervious_blanket rdf:type owl:NamedIndividual .


###  http://ontogeo.kz/geont-kz#Upstream_face_impervious_blanket_Concept
:Upstream_face_impervious_blanket_Concept rdf:type owl:NamedIndividual ,
                                                   ontolex:LexicalConcept ;
                                          ontolex:isConceptOf :Upstream_face_impervious_blanket ;
                                          rdfs:comment "Seepage barrier on upstream face of a dam"@en ,
                                                       "Бөгеттің үстіңгі беткейі жағында орналасқан, су аз өткізетін (сазды) топырақтардан немесе топырақты емес (бетон, асфальтбетон, полимерлі қабықшалар және т.б.) материалдардан жасалатын сүзілуге қарсы құрылғы."@kz ,
                                                       "Противофильтрационное устройство, расположенное со стороны верхового откоса плотины, устраиваемое из маловодопроницаемых( глинистых) грунтов или негрунтовых( бетон, асфальтобетон, полимерные пленкии др.) материалов"@ru ;
                                          rdfs:isDefinedBy "СП РК 3.04-105-2014 Плотины из грунтовых материалов (Document_347e1ac7-6a7c-458d-a054-19ce0a5c31f9)" ;
                                          rdfs:label "upstream face impervious blanket"@en ,
                                                     "бөгет экраны"@kz ,
                                                     "экран плотины"@ru .


