:Ground_heave_Concept rdf:type owl:NamedIndividual ,
                               ontolex:LexicalConcept ;
                      ontolex:isConceptOf :Ground_heave ;
                      rdfs:comment "Upward movement of ground adjacent to an excavation when dense material is rammed into its base"@en ,
                                   "Подъем поверхности грунта вокруг котлована при его вытрамбовывании и втрамбовывании в его дно жесткого материала"@ru ,
                                   "Шұңқырды тығыздап жасау және оның түбіне қатты материалды (мысалы, қиыршық тас) тығыздап енгізу кезінде шұңқырдың айналасындағы топырақ бетінің көтерілуі"@kz ;
                      rdfs:isDefinedBy "СП РК 5.01-105-2013 Фундаменты в вытрамбованных котлованах (Document_3d02602d-27a5-4420-8822-7691a7724982)" ;
                      rdfs:label "ground heave"@en ,
                                 "выпор грунта"@ru ,
                                 "топырақтың шығуы"@kz .


