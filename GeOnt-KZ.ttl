                           ontolex:isConceptOf :Trench_panel_grab ;
                           rdfs:comment "Individual panel of a slurry trench prepared for concreting or for placing precast elements"@en ,
                                        "Кейіннен бетондау немесе құрама элементтермен толтырып, монолиттеу үшін жасалатын траншеяның бөлігі"@kz ,
                                        "Фрагмент траншеи, разрабатываемый для последующего бетонирования или заполнения сборными элементами с омоноличиванием"@ru ;
                           rdfs:isDefinedBy "СН РК 5.01-01-2013 Земляные сооружения, основания и фундаменты (Document_97057d47-3060-42cc-bc25-2af554423c81)" ;
                           rdfs:label "trench panel (grab)"@en ,
                                      "Траншеяның захваткасы"@kz ,
                                      "захватка траншеи"@ru .


