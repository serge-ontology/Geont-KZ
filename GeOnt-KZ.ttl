                                         ontolex:MultiWordExpression ;
                                ontolex:evokes :Planestress_state_Concept ;
                                rdfs:label "plane-stress state"@en ,
                                           "плоское напряженное состояние"@ru ,
                                           "тегіс кернеу күйі"@kz .


###  http://ontogeo.kz/geont-kz#Plastic_frozen_soil
:Plastic_frozen_soil rdf:type owl:NamedIndividual .


###  http://ontogeo.kz/geont-kz#Plastic_frozen_soil_Concept
:Plastic_frozen_soil_Concept rdf:type owl:NamedIndividual ,
                                      ontolex:LexicalConcept ;
                             ontolex:isConceptOf :Plastic_frozen_soil ;
                             rdfs:comment "Frozen soil cemented by ice, exhibiting viscoplastic behaviour under load"@en ,
                                          "Мұзбен цементтелген, тұтқыр-пластикалық қасиеттерге және сыртқы жүктеме әсерінен сығылғыштыққа ие дисперсті топырақ."@kz ,
                                          "дисперсный грунт, сцементированный льдом, обладающий вязко-пластичными свойствами и сжимаемостью под внешней нагрузкой"@ru ;
                             rdfs:isDefinedBy "СТ РК 2156-2-2011 Геотехнические исследования и испытания Идентификация и классификация грунтов. Часть 2. Принципы и классификация (Document_4a01341f-420d-4f8a-a08f-e72abc9955e4)" ;
                             rdfs:label "plastic frozen soil"@en ,
                                        "пластикалық мұздатылған топырақ"@kz ,
                                        "пластичномерзлый грунт"@ru .


