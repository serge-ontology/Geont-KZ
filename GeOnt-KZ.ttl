                                ontolex:LexicalConcept ;
                       ontolex:isConceptOf :Stripcap_beam ;
                       rdfs:comment "RC beam tying diaphragm-wall panels and supporting superstructure"@en ,
                                    "Железобетонная балка, устанавливаемая над уровнем отсечки для соединения панелей из стен, бетонируемых в траншее и/ или соединения с вышележащими элементами конструкции"@ru ,
                                    "Траншеяда бетондалатын қабырғалардан жасалған панельдерді қосу және/немесе жоғарыда жатқан конструкция элементтерімен қосу үшін кесу деңгейінен жоғары орнатылатын темірбетон арқалық."@kz ;
                       rdfs:isDefinedBy "СТ РК EN 1538-2012 Выполнение специальных геотехнических работ. Стены в грунте (Document_f7c53fbf-8948-4734-974c-d1fdf444001b)" ;
                       rdfs:label "strip-cap beam"@en ,
                                  "ростверк ленточного свайного фундамента"@ru ,
                                  "таспалы қадалы іргетастың ростверкі"@kz .


