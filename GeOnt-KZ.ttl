                                            ontolex:evokes :Strengthening_of_rc_structure_Concept ;
                                            rdfs:label "strengthening of RC structure"@en ,
                                                       "темірбетон құрылымын нығайту"@kz ,
                                                       "усиление железобетонной конструкции"@ru .


###  http://ontogeo.kz/geont-kz#Strengthening_strips
:Strengthening_strips rdf:type owl:NamedIndividual .


###  http://ontogeo.kz/geont-kz#Strengthening_strips_Concept
:Strengthening_strips_Concept rdf:type owl:NamedIndividual ,
                                       ontolex:LexicalConcept ;
                              ontolex:isConceptOf :Strengthening_strips ;
                              rdfs:comment "FRP laminates or fibre fabrics prepared for bonding to concrete"@en ,
                                           "Ламинаты или их части, или части изделий из непрерывного углеродного или стеклянного волокна( холсты, сетки и другие тканые материалы), различной длины и ширины, подготовленные для наклеивания на основание железобетонной конструкции"@ru ,
                                           "Темірбетон конструкциясының негізіне жапсыруға дайындалған, әртүрлі ұзындықтағы және ендегі ламинаттар немесе олардың бөліктері, немесе үздіксіз көміртекті немесе шыны талшықтан жасалған бұйымдардың (кенептер, торлар және басқа да тоқыма материалдар) бөліктері."@kz ;
                              rdfs:isDefinedBy "СП 164.1325800.2014 Усиление железобетонных конструкций композитными материалами. Правила проектирования (Document_f3a93e50-b23c-4e83-acca-84e08bf6191a)" ;
                              rdfs:label "strengthening strips"@en ,
                                         "күшейту элементтері"@kz ,
                                         "элементы усиления"@ru .


