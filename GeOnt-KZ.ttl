                                    ontolex:LexicalConcept ;
                           ontolex:isConceptOf :Enlarged_base_pad ;
                           rdfs:comment "Compacted soil–stone bulb formed at bottom of tamped pit"@en ,
                                        "Кеңейтілген негіз: қатты материалдың түбіне бұралған кезде шұңқырдың төменгі бөлігінде пайда болатын топырақ пен қатты материалдың тығыздалған қоспасынан жасалған қабық"@kz ,
                                        "Уширенное основание: Оболочка из уплотненного смеси грунта и жесткого материала, которая формируется в нижней части котлована при в трамбовывании в его дно жесткого материала"@ru ;
                           rdfs:isDefinedBy "СП РК 5.01-107-2013 Контроль несущей способности фундаментов (ФВК) по результатам вытрамбовывания их котлованов (Document_6df2c6f6-ffd9-43e9-9120-5084265388ff)" ;
                           rdfs:label "enlarged base pad"@en ,
                                      "кеңейтілген негіз"@kz ,
                                      "уширенное основание"@ru .


