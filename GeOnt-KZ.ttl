:Standard_compaction_Concept rdf:type owl:NamedIndividual ,
                                      ontolex:LexicalConcept ;
                             ontolex:isConceptOf :Standard_compaction ;
                             rdfs:comment "Laboratory compaction with fixed hammer energy (Proctor)"@en ,
                                          "Послойное (в три слоя) уплотнение образца грунта с постоянной работой уплотнения"@ru ,
                                          "Тұрақты тығыздау жұмысымен топырақ үлгісін қабаттап (үш қабатпен) тығыздау."@kz ;
                             rdfs:isDefinedBy "СП РК 5.01-108-2013 Оперативный контроль плотности грунтов в условиях строительной площадки при их уплотнении (Document_77ef0b46-5b03-451e-8eef-1f22930afc62)" ;
                             rdfs:label "standard compaction"@en ,
                                        "стандартное уплотнение"@ru ,
                                        "стандартты тығыздау"@kz .


