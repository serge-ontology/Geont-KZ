:Structure_Concept rdf:type owl:NamedIndividual ,
                            ontolex:LexicalConcept ;
                   ontolex:isConceptOf :Structure ;
                   rdfs:comment "Organised assembly of components intended to carry loads"@en ,
                                "Жүктемелерді көтеруге және қажетті қатаңдықты қамтамасыз етуге арналған байланысқан бөліктердің (құрылыс жұмыстарын орындау кезінде төселген үйінді топырақты қоса алғанда) ұйымдастырылған кешені."@kz ,
                                "Организованный комплекс связанных частей (включая насыпной грунт, уложенный при выполнении строительных работ) предназначенный для того, чтобы нести нагрузки и обеспечивать необходимую жесткость"@ru ;
                   rdfs:isDefinedBy "НТП_РК_07_01_4_2012_к_СН_РК_EN_СН_РК_EN_1997_1_20042011_Геотехническое (Document_3d37a86c-6e58-405f-bb44-db4a878c9131)" ;
                   rdfs:label "structure"@en ,
