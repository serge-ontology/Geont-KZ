                         ontolex:isConceptOf :Hoisting_cables ;
                         rdfs:comment "Steel ropes suspending excavation tool"@en ,
                                      "Стальной трос, поддерживающий инструмент для выемки грунта для глубокой выемки грунта"@ru ,
                                      "Терең топырақ алу үшін топырақ алу құралын ұстап тұратын болат трос"@kz ;
                         rdfs:isDefinedBy "СТ РК EN 1538-2012 Выполнение специальных геотехнических работ. Стены в грунте (Document_f7c53fbf-8948-4734-974c-d1fdf444001b)" ;
                         rdfs:label "hoisting cables"@en ,
