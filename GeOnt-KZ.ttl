:Tamping_regime rdfs:comment "Schedule of drop height or blow count during dynamic compaction"@en ,
                             "Порядок изменения высоты сбрасывания трамбовки по мере нанесения ударов по грунту котлована, представляемый часто в графическом виде"@ru ,
                             "Шұңқыр топырағына соққы беру барысында тығыздағышты түсіру биіктігінің өзгеру тәртібі, көбінесе графикалық түрде ұсынылады."@kz ;
                rdfs:label "tamping regime"@en ,
                           "режим приложения ударной нагрузки"@ru ,
                           "соққы жүктемесін қолдану режимі"@kz .


:Tectonic_earthquake rdfs:comment "Ground surface oscillations generated by seismic waves"@en ,
                                  "Колебания земной поверхности в результате прохождения сейсмических волн"@ru ,
                                  "Сейсмикалық толқындардың өтуі нәтижесінде жер бетінің тербелісі"@kz ;
                     rdfs:label "tectonic earthquake"@en ,
                                "жер сілкінісі (тектоникалық)"@kz ,
                                "землетрясение (тектоническое)"@ru .


:Temporary_anchor rdfs:comment "Ground anchor designed for a service life of less than two years"@en ,
                               "анкер с запланированным сроком службы менее 2 лет"@ru ,
                               "жоспарланған қызмет мерзімі 2 жылдан аз анкер"@kz ;
                  rdfs:label "temporary anchor"@en ,
                             "кратковременный анкер"@ru ,
                             "қысқа анкер"@kz .


:Temporary_ground_anchor rdfs:comment "Ground anchor designed for a service life not exceeding two years"@en ,
                                      "Грунтовый анкер с расчетным сроком эксплуатации не более двух лет"@ru ,
                                      "Есептік пайдалану мерзімі екі жылдан аспайтын топырақ анкер"@kz ;
                         rdfs:label "temporary ground anchor"@en ,
                                    "временный анкер"@ru ,
                                    "уақытша анкер"@kz .


:Temporary_retaining_diaphragm_wall rdfs:comment "Slurry wall used solely as temporary excavation support"@en ,
                                                 "Стена в грунте, предназначенная для использования только в качестве временного ограждения строительного котлована (выемки)"@ru ,
                                                 "Құрылыс шұңқырының (қазбасының) тек уақытша қоршауы ретінде пайдалануға арналған топырақтағы қабырға."@kz ;
                                    rdfs:label "temporary retaining diaphragm wall"@en ,
                                               "жердегі қоршау қабырғасы"@kz ,
                                               "ограждающая стена в грунте"@ru .


:Tendon_anchor rdfs:comment "Tension member conveying load from bond zone to anchor head"@en ,
                            "Күш түсіру ұзындығынан анкер басына созу күшін беретін жерге тұйықталған анкердің бөлігі."@kz ,
                            "часть заземленного анкера, передающая растягивающее усилие от длины приложения усилия к головке анкера"@ru ;
               rdfs:label "tendon (anchor)"@en ,
                          "растягивающий элемент анкера"@ru ,
                          "анкер созылу элементі" .


:Test_load rdfs:comment "Peak load applied to an anchor during a load test"@en ,
                        "максимальное усилие, которое прикладывается к анкеру во время испытания"@ru ,
                        "сынақ кезінде анкерге қолданылатын максималды күш"@kz ;
           rdfs:label "test load"@en ,
                      "испытательное усилие"@ru ,
                      "сынақ күші"@kz .


:Theoretical_hammer_energy rdfs:comment "Potential energy of hammer (mass × g × drop height)"@en ,
                                        "Рассчитанная энергия для ударно_забивного механизма: Etheor = m · g · h, где m- масса молота,"@ru ,
                                        "Соққылы-қағу механизмі үшін есептелген энергия: Etheor = m · g · h, мұндағы m - балға массасы,"@kz ;
                           rdfs:label "etheor теориялық энергиясы"@kz ,
                                      "theoretical hammer energy"@en ,
                                      "теоретическая энергия etheor"@ru .


:Thinelement_retaining_structure rdfs:comment "Slender retaining wall relying mainly on soil weight above base slab"@en ,
                                              "Жұқа элементті қаттаушы құрылыс: тұрақтылығы негізінен іргетас плитасы үстіндегі топырақтың салмағымен және аз дәрежеде конструкцияның өз салмағымен қамтамасыз етілетін қаттаушы құрылыс"@kz ,
                                              "Тонкоэлементное подпорное сооружение: Подпорное сооружение, устойчивость которого обеспечивается в основном весом грунта над фундаментной плитой и в небольшой степени собственным весом конструкции"@ru ;
                                 rdfs:label "thin-element retaining structure"@en ,
                                            "жұқа элементті тірек құрылымы"@kz ,
                                            "тонкоэлементное подпорное сооружение"@ru .


:Transition_zones rdfs:comment "Filter layers between low-permeability core and coarse shell in a rock-earth dam"@en ,
                               "Сүзілуге қарсы құрылғылар топырағының сүзілу деформацияларын болдырмауға арналған, топырақты сүзілуге қарсы құрылғылар мен бөгет денесінің ірі кесекті материалының жанасуында жасалатын тасты-топырақты бөгеттердің элементі."@kz ,
                               "Элемент каменно-земляных плотин, устраиваемый на контакте грунтовых противофильтрационных устройств и крупнообломочного материала тела плотины и предназначенный для предотвращения фильтрационных деформаций грунта противофильтрационных устройств"@ru ;
                  rdfs:label "transition zones"@en ,
                             "переходные слои"@ru ,
                             "өтпелі қабаттар"@kz .


:Tremie_concreting rdfs:comment "Placing concrete into a borehole or trench through a vertically movable tremie pipe"@en ,
                                "Бетонды ұңғымаға немесе траншеяға тігінен жылжытылатын бетон құбырын қолдану арқылы төсеу әдісі"@kz ,
                                "Метод укладки бетона в скважину или траншею применением вертикально-перемещаемой бетонолитной трубы"@ru ;
                   rdfs:label "tremie concreting"@en ,
                              "впт"@ru ,
                              "тігінен қозғалатын құбыр әдісі"@kz .


:Trench_panel_grab rdfs:comment "Individual panel of a slurry trench prepared for concreting or for placing precast elements"@en ,
                                "Кейіннен бетондау немесе құрама элементтермен толтырып, монолиттеу үшін жасалатын траншеяның бөлігі"@kz ,
                                "Фрагмент траншеи, разрабатываемый для последующего бетонирования или заполнения сборными элементами с омоноличиванием"@ru ;
                   rdfs:label "trench panel (grab)"@en ,
                              "Траншеяның захваткасы"@kz ,
                              "захватка траншеи"@ru .


:Trimming rdfs:comment "Removal of over-break concrete and bentonite slurry crust from diaphragm-wall panel top"@en ,
                       "Траншеяда бетондалған қабырғалардан панельдерді ашу кезінде артық бетонды (шығыңқы жерлерін және т.б.) және бентонит шөгіндісін кетіру."@kz ,
                       "Удаление лишнего бетона (выступов ит.д.) и бентонитового осадка при обнажении панелей из стен, бетонируемых в траншее"@ru ;
          rdfs:label "trimming"@en ,
                     "кесу"@kz ,
                     "обрезка"@ru .


:Tunnel rdfs:comment "Horizontal or inclined underground passage ≥ 2 m clearance"@en ,
                     "Тоннель( tunnel): Горизонтальное или наклонное протяженное подземное сооружение высотой2 м и более до выступающих конструкций, предназначенное для прокладки железных и автомобильных дорог, пешеходных переходов, коммуникаций ит.д."@ru ,
                     "Туннель (tunnel): биіктігі шығыңқы конструкцияларға дейін 2 м және одан жоғары болатын, темір жол мен автомобиль жолдарын, жаяу жүргіншілер өткелін, коммуникацияларды және т.б. салу үшін арналған көлденең немесе қисық ұзын жер асты құрылысы"@kz ;
        rdfs:label "tunnel"@en ,
                   "тоннель"@ru ,
                   "туннель"@kz .


:Ultimate_foundation_deformations rdfs:comment "Movements whose exceedance may induce structural failure or endanger life"@en ,
                                               "Асып кетуі ғимараттардың апаттық жағдайын немесе адамдардың өміріне қауіп төндіретін деформациялар."@kz ,
                                               "Деформации, превышение которых может вызвать аварийное состояние сооружений или угрозу опасности для жизни людей"@ru ;
                                  rdfs:label "ultimate foundation deformations"@en ,
                                             "деформации основания сооружений предельные"@ru ,
                                             "құрылыстар негізінің шекті деформациясы"@kz .


:Ultimate_limit_states rdfs:comment "States corresponding to collapse or other structural failure modes"@en ,
                                    "Жүк көтергіш құрылымның бұзылуына немесе істен шығуының басқа түрлеріне байланысты жағдайлар"@kz ,
                                    "Состояния, связанные с разрушением или другими формами отказа несущей конструкции"@ru ;
                       rdfs:label "ultimate limit states"@en ,
                                  "жүк көтергіштігінің шекті күйлері"@kz ,
                                  "предельные состояния несущей способности"@ru .


:Ultrasonic_integrity_test rdfs:comment "Pulse transmission of ultrasonic waves through concrete to detect pile defects"@en ,
                                        "целостное испытание сваи, при котором серия звуковых волн от передатчика через бетон сваи подается на приемник, при этом характеристики принятых волн замеряются и используются для установления неразрывности ствола сваи и изменений сечения"@ru ,
                                        "Қазық діңінің үзіліссіздігі мен қимасының өзгерістерін анықтау мақсатында жүргізілетін сынау, оның барысында таратқыштан жіберілген дыбыс толқындарының сериясы қазықтың бетоны арқылы қабылдағышқа беріліп, қабылданған толқындардың сипаттамалары өлшенеді"@kz ;
                           rdfs:label "ultrasonic integrity test"@en ,
                                      "испытание ультразвуком"@ru ,
                                      "ультрадыбыстық сынақ"@kz .


:Unacceptable_deviations rdfs:comment "Variations that hinder normal use or necessitate structural strengthening"@en ,
                                      "Конструкцияларды қалыпты пайдалануға кедергі келтіретін немесе есептік схемаға өзгерістер енгізу арқылы конструкцияларды күшейтуді талап ететін ауытқулар."@kz ,
                                      "Отклонения, которые создают препятствия нормальной эксплуатации конструкций или вносят такие изменения в расчетную схему, учет которых требует усиления конструкций"@ru ;
                         rdfs:label "unacceptable deviations"@en ,
                                    "Рұқсат етілмейтін ауытқулар"@kz ,
                                    "отклонения недопустимые"@ru .


:Underground_structure rdfs:comment "Structure located wholly or partly below ground level"@en ,
                                    "Жер бетінің деңгейінен төмен орналасқан құрылыс немесе құрылыстың бөлігі."@kz ,
                                    "сооружение или часть сооружения, расположенная ниже уровня поверхности земли"@ru ;
                       rdfs:label "underground structure"@en ,
                                  "жерасты құрылысы немесе құрылыстың жерасты бөлігі"@kz ,
                                  "подземное сооружение или подземная часть сооружения"@ru .


:Undermined_area rdfs:comment "Territory subject to ground movements due to subsurface workings"@en ,
                              "Жер асты тау-кен жұмыстарын жүргізу нәтижесінде ғимараттар мен құрылыстардың негізіндегі топырақтың біркелкі емес шөгуі немесе ығысуы пайда болуы мүмкін аумақ."@kz ,
                              "Территория, на которой в результате проведения подземных горных работ могут возникнуть неравномерные оседания или смещения грунта в основании зданий или сооружений"@ru ;
                 rdfs:label "undermined area"@en ,
                            "жұмыс істейтін аумақ"@kz ,
                            "подрабатываемая территория"@ru .


:Undermined_development rdfs:comment "Existing structures located above areas affected by underground mining"@en ,
                                     "Существующие здания, сооружения и инженерные коммуникации, расположенные на подрабатываемых территориях"@ru ,
                                     "Өңделетін аумақтарда орналасқан қолданыстағы ғимараттар, құрылыстар және инженерлік коммуникациялар."@kz ;
                        rdfs:label "undermined development"@en ,
                                   "жұмыс істейтін құрылыс"@kz ,
                                   "подрабатываемая застройка"@ru .


:Undermining_of_structure rdfs:comment "Excavation of mineral workings beneath a structure that affects its foundation"@en ,
                                       "Пайдалы қазбаларды өндіру немесе нысанға әсер ететін түрлі мақсаттағы жер асты құрылыстарын салу мақсатында жер асты тау-кен қазбаларын өту."@kz ,
                                       "Проходка подземных горных выработок с целью выемки полезных ископаемых или строительства подземных сооружений различного назначения, оказывающих влияние на объект"@ru ;
                          rdfs:label "undermining of structure"@en ,
                                     "объектіні қосымша өңдеу"@kz ,
                                     "подработка объекта"@ru .


:Upstream_blanket_cutoff rdfs:comment "Low-permeability horizontal layer extending seepage path beneath a dam"@en ,
                                      "Бөгет экранына немесе ядросына жанасып орналасқан, су өткізгіштігі төмен топырақтардан жасалған және негіз топырағындағы бөгет астындағы сүзілу ағынының жолын ұзартуға арналған көлденең сүзілуге қарсы құрылғы."@kz ,
                                      "Горизонтальное противофильтрационное устройство, примыкающее к экрану или ядру плотины, устраиваемое из маловодопроницаемых грунтов и предназначенное для удлинения пути фильтрационного потока под плотиной в грунте основания"@ru ;
                         rdfs:label "upstream blanket (cut-off)"@en ,
                                    "понур бөгеттері"@kz ,
                                    "понур плотины"@ru .


:Upstream_face_impervious_blanket rdfs:comment "Seepage barrier on upstream face of a dam"@en ,
                                               "Бөгеттің үстіңгі беткейі жағында орналасқан, су аз өткізетін (сазды) топырақтардан немесе топырақты емес (бетон, асфальтбетон, полимерлі қабықшалар және т.б.) материалдардан жасалатын сүзілуге қарсы құрылғы."@kz ,
                                               "Противофильтрационное устройство, расположенное со стороны верхового откоса плотины, устраиваемое из маловодопроницаемых( глинистых) грунтов или негрунтовых( бетон, асфальтобетон, полимерные пленкии др.) материалов"@ru ;
                                  rdfs:label "upstream face impervious blanket"@en ,
                                             "бөгет экраны"@kz ,
                                             "экран плотины"@ru .


:Upstream_reach rdfs:comment "Reach located upstream of a dam or weir"@en ,
                             "Бьеф с верховой стороны водоподпорного сооружения"@ru ,
                             "Су тіреу құрылысының жоғарғы жағындағы бьеф"@kz ;
                rdfs:label "upstream reach"@en ,
                           "верхний бьеф"@ru ,
                           "жоғарғы бьеф"@kz .


:Upstream_slope rdfs:comment "Slope of a dam facing the upstream reach"@en ,
                             "Бөгеттің жоғарғы бьеф жағындағы беті"@kz ,
                             "Поверхность плотины со стороны верхнего бьефа"@ru ;
                rdfs:label "upstream slope"@en ,
                           "верховой откос"@ru ,
                           "жоғары беткейі"@kz .


:Vertical_groundsurface_deformations rdfs:comment "Vertical displacements of the ground surface caused by uneven vertical movements"@en ,
                                                  "Деформации земной поверхности в вертикальной плоскости, вызванные неравномерностью вертикальных сдвижений"@ru ,
                                                  "Тікелей (вертикалды) ығысулардың біркелкі болмауынан туындаған, жер бетінің вертикалды жазықтықтағы деформациялары"@kz ;
                                     rdfs:label "vertical ground-surface deformations"@en ,
                                                "деформация земной поверхности вертикальная"@ru ,
                                                "жер бетінің тік деформациясы"@kz .


:Vibration_damping rdfs:comment "Reduction of vibration amplitude through mechanical energy dissipation"@en ,
                                "механикалық энергияның шашырауына байланысты вибрацияның азаюы"@kz ,
                                "уменьшение вибрации вследствие рассеяния механической энергии"@ru ;
                   rdfs:label "vibration damping"@en ,
                              "демпфирование вибрации"@ru ,
                              "дірілді демпферлеу"@kz .


:Vibrationinduced_liquefaction rdfs:comment "Loss of bearing capacity of fine sandy soils due to sudden pore-pressure rise under dynamic loading"@en ,
                                            "Динамикалық әсер кезінде кеуек қысымының күрт жоғарылауына байланысты ұсақ құмды топырақтардың жүк көтергіштігінің жоғалуы"@kz ,
                                            "Потеря несущей способности мелкодисперсных песчаных грунтов вследствие резкого увеличения парового давления при динамических воздействиях"@ru ;
                               rdfs:label "vibration-induced liquefaction"@en ,
                                          "виброразжижение грунта"@ru ,
                                          "топырақтың дірілді сұйылтуы"@kz .


:Void_gap rdfs:comment "Space between ground and structural surface or between adjacent structures"@en ,
                       "Полость между грунтом и поверхностью конструкции или внешними поверхностями смежных конструкций (например, полость между ограждением котлована и возводимым фундаментом)"@ru ,
                       "Топырақ пен конструкция бетінің немесе іргелес конструкциялардың сыртқы беттерінің арасындағы қуыс (мысалы, шұңқыр қоршауы мен салынып жатқан іргетастың арасындағы қуыс)."@kz ;
          rdfs:label "void (gap)"@en ,
