###  http://ontogeo.kz/geont-kz#Hard_frozen_soil
:Hard_frozen_soil rdf:type owl:NamedIndividual .


###  http://ontogeo.kz/geont-kz#Hard_frozen_soil_Concept
:Hard_frozen_soil_Concept rdf:type owl:NamedIndividual ,
                                   ontolex:LexicalConcept ;
                          ontolex:isConceptOf :Hard_frozen_soil ;
                          rdfs:comment "Ice-cemented frozen soil behaving as brittle, nearly incompressible material"@en ,
                                       "Мұзбен берік цементтелген, салыстырмалы түрде морт бұзылумен сипатталатын, сыртқы жүктеме әсерінен іс жүзінде сығылмайтын дисперсті топырақ."@kz ,
                                       "дисперсный грунт, прочно сцементированный льдом, характеризуемый относительно хрупким разрушением, практически несжимаемый под внешней нагрузкой"@ru ;
                          rdfs:isDefinedBy "СТ РК 2156-2-2011 Геотехнические исследования и испытания Идентификация и классификация грунтов. Часть 2. Принципы и классификация (Document_4a01341f-420d-4f8a-a08f-e72abc9955e4)" ;
                          rdfs:label "hard frozen soil"@en ,
                                     "твердомерзлый грунт"@ru ,
                                     "қатты мұздатылған топырақ"@kz .


###  http://ontogeo.kz/geont-kz#Hard_frozen_soil_LexicalEntry
:Hard_frozen_soil_LexicalEntry rdf:type owl:NamedIndividual ,
                                        ontolex:MultiWordExpression ;
                               ontolex:evokes :Hard_frozen_soil_Concept ;
                               rdfs:label "hard frozen soil"@en ,
                                          "твердомерзлый грунт"@ru ,
                                          "қатты мұздатылған топырақ"@kz .


###  http://ontogeo.kz/geont-kz#High_groundwaterlevel_area
:High_groundwaterlevel_area rdf:type owl:NamedIndividual .


###  http://ontogeo.kz/geont-kz#High_groundwaterlevel_area_Concept
:High_groundwaterlevel_area_Concept rdf:type owl:NamedIndividual ,
                                             ontolex:LexicalConcept ;
                                    ontolex:isConceptOf :High_groundwaterlevel_area ;
                                    rdfs:comment "Area where maximum groundwater depth is 0.4–1.0 m below ground surface"@en ,
                                                 "Территория, в пределах которой максимальная глубина расположения уровня грунтовых вод от поверхности земли составляет 0,4-1,0 м"@ru ,
                                                 "Шегінде жер асты сулары деңгейінің жер бетінен ең үлкен орналасу тереңдігі 0,4-1,0 м құрайтын аумақ"@kz ;
                                    rdfs:isDefinedBy "СП РК 4.02-109-2014 Проектирование и строительство городских тепловых сетей в зонах с высоким уровнем грунтовых вод (Document_88493977-bf6f-4b00-b36e-701f5fae8f67)" ;
                                    rdfs:label "high groundwater-level area"@en ,
                                               "жер асты суларының деңгейі жоғары аймақ"@kz ,
                                               "зона с высоким уровнем грунтовых вод"@ru .


###  http://ontogeo.kz/geont-kz#High_groundwaterlevel_area_LexicalEntry
:High_groundwaterlevel_area_LexicalEntry rdf:type owl:NamedIndividual ,
                                                  ontolex:MultiWordExpression ;
                                         ontolex:evokes :High_groundwaterlevel_area_Concept ;
                                         rdfs:label "high groundwater-level area"@en ,
                                                    "жер асты суларының деңгейі жоғары аймақ"@kz ,
                                                    "зона с высоким уровнем грунтовых вод"@ru .


###  http://ontogeo.kz/geont-kz#Hoisting_cables
:Hoisting_cables rdf:type owl:NamedIndividual .


