:Cone_resistance_Concept rdf:type owl:NamedIndividual ,
                                  ontolex:LexicalConcept ;
                         ontolex:isConceptOf :Cone_resistance ;
                         rdfs:comment "Unit resistance of soil to static cone penetration"@en ,
                                      "Сопротивление грунта внедрению конического наконечника под действием статической нагрузки на глубину, меньшую, чем высота наконечника"@ru ,
                                      "Статикалық жүктеменің әсерінен конус тәрізді ұштықтың оның биіктігінен аз тереңдікке енуіне топырақтың кедергісі."@kz ;
                         rdfs:isDefinedBy "СП РК 5.01-108-2013 Оперативный контроль плотности грунтов в условиях строительной площадки при их уплотнении (Document_77ef0b46-5b03-451e-8eef-1f22930afc62)" ;
                         rdfs:label "cone resistance"@en ,
                                    "топырақтың енуіне ерекше қарсылық"@kz ,
                                    "удельное сопротивление пенетрации грунта"@ru .


