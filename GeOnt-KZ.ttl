                                       ontolex:isConceptOf :Bonded_fixed_length_of_tendon ;
                                       rdfs:comment "Portion of a tendon bonded to grout, transmitting tensile load to ground"@en ,
                                                    "Нығыздалатын денемен тікелей байланысқан және түсірілген созу күшін беретін созылған элементтің ұзындығы"@kz ,
                                                    "длина растягивающего элемента, которая напрямую соединена с запрессовываемым объектом и которая передает прикладываемое растягивающее усилие"@ru ;
                                       rdfs:isDefinedBy "СТ РК ЕN 1537-2011 Выполнение специальных геотехнических работ. Грунтовые анкеры (Document_86288b05-c9b3-406e-aa3f-86d5bdf17a4b)" ;
                                       rdfs:label "bonded (fixed) length of tendon"@en ,
                                                  "зажимная длина растягивающего элемента"@ru ,
                                                  "созылу элементінің қысқыш ұзындығы"@kz .


