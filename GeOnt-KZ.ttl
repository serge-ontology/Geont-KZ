                               ontolex:evokes :Drainage_element_Concept ;
                               rdfs:label "drainage element"@en ,
                                          "дренаж құрылғысы"@kz ,
                                          "дренажное устройство"@ru .


###  http://ontogeo.kz/geont-kz#Drive_rod
:Drive_rod rdf:type owl:NamedIndividual .


###  http://ontogeo.kz/geont-kz#Drive_rod_Concept
:Drive_rod_Concept rdf:type owl:NamedIndividual ,
                            ontolex:LexicalConcept ;
                   ontolex:isConceptOf :Drive_rod ;
                   rdfs:comment "Rod linking drop hammer to cone or sampler"@en ,
                                "Rod that connects the hammer/drive assembly to the sampler or cone"@en ,
                                "Соққы штангасы (drive rods): соққылы-қағу механизмін конусқа қосатын штанга"@kz ,
                                "Соққы-қағу механизмін сынама алғышпен жалғайтын штанга"@kz ,
                                "Ударная штанга (drive rods): Штанга, которая подсоединяет ударно-забивной механизм к конусу"@ru ,
                                "Штанга, которая подсоединяет ударно-забивной механизм к пробоотборнику"@ru ;
                   rdfs:isDefinedBy "СТ РК ISO 22476-2-2012 Геотехнические исследования и испытания. Полевые испытания. Часть 2. Динамическое зондирование (Document_203f9a0d-25a2-4a98-9e5f-141db75c24f7)" ,
                                    "СТ РК ISO 22476-3-2012 Геотехнические исследования и испытания. Полевые испытания. Часть 3. Стандартные испытания на пенетрацию (Document_8848b31a-3d01-4055-bb23-7471868f31b2)" ;
                   rdfs:label "drive rod"@en ,
                              "жетек штангасы"@kz ,
                              "забивная штанга"@ru ,
                              "соққы штангасы"@kz ,
                              "ударная штанга"@ru .


