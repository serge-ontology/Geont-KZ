                                        ontolex:MultiWordExpression ;
                               ontolex:evokes :Grouting_refusal_Concept ;
                               rdfs:label "grouting refusal"@en ,
                                          "отказ при проведении цементации"@ru ,
                                          "цементтеу кезінде бас тарту"@kz .


###  http://ontogeo.kz/geont-kz#Guide_frame
:Guide_frame rdf:type owl:NamedIndividual .


###  http://ontogeo.kz/geont-kz#Guide_frame_Concept
:Guide_frame_Concept rdf:type owl:NamedIndividual ,
                              ontolex:LexicalConcept ;
                     ontolex:isConceptOf :Guide_frame ;
                     rdfs:comment "Vertical steel guide along which the rig carriage travels up/down"@en ,
                                  "Металлическая вертикальная конструкция, как правило, коробчатого поперечного сечения, по которой движется каретка установки при подъеме и сбрасывании трамбовки"@ru ,
                                  "Тығыздағышты көтеру және тастау кезінде бойымен қондырғының кареткасы қозғалатын, әдетте, қорап тәрізді көлденең қимасы бар металл тік конструкция."@kz ;
                     rdfs:isDefinedBy "СП РК 5.01-107-2013 Контроль несущей способности фундаментов (ФВК) по результатам вытрамбовывания их котлованов (Document_6df2c6f6-ffd9-43e9-9120-5084265388ff)" ;
                     rdfs:label "guide frame"@en ,
                                "Орнату нұсқаулығы"@kz ,
                                "направляющая установки"@ru .


###  http://ontogeo.kz/geont-kz#Guide_frame_LexicalEntry
