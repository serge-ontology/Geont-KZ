                       ontolex:isConceptOf :Friction_pile ;
                       rdfs:comment "Pile carrying load chiefly through shaft resistance"@en ,
                                    "Жүктемені негізге бүйір беті мен табаны арқылы беретін қада."@kz ,
                                    "Свая, передающая нагрузку на основание через боковую поверхность и пяту"@ru ;
                       rdfs:isDefinedBy "НТП РК 08.05.1-2022 Проектирование оснований и фундаментов зданий и сооружений в сейсмических районах (Document_4a85e34a-20fa-49f7-bbc3-4aeca1ebd5d1)" ;
                       rdfs:label "friction pile"@en ,
