###  http://ontogeo.kz/geont-kz#Sleeperpile_foundation_Concept
:Sleeperpile_foundation_Concept rdf:type owl:NamedIndividual ,
                                         ontolex:LexicalConcept ;
                                ontolex:isConceptOf :Sleeperpile_foundation ;
                                rdfs:comment "Foundation formed by driving precast sleeper blocks"@en ,
                                             "Негізгі көтергіш элементтері теміржол шпалдары түріндегі, топыраққа қағу арқылы жеке-жеке батырылатын қағылмалы блоктар болып табылатын іргетас."@kz ,
                                             "Фундамент, в котором основными несущими элементами служат забивные блоки в виде железнодорожных шпал, погружаемые в грунт каждый в отдельности путем забивки"@ru ;
                                rdfs:isDefinedBy "СП РК 5.01-107-2013 Контроль несущей способности фундаментов (ФВК) по результатам вытрамбовывания их котлованов (Document_6df2c6f6-ffd9-43e9-9120-5084265388ff)" ;
                                rdfs:label "sleeper-pile foundation"@en ,
                                           "шпал негізі"@kz ,
                                           "шпальный фундамент"@ru .


