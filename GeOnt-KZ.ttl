                                   rdfs:label "grouting (cementation)"@en ,
                                              "цементация"@ru ,
                                              "цементтеу"@kz .


###  http://ontogeo.kz/geont-kz#Grouting_refusal
:Grouting_refusal rdf:type owl:NamedIndividual .


###  http://ontogeo.kz/geont-kz#Grouting_refusal_Concept
:Grouting_refusal_Concept rdf:type owl:NamedIndividual ,
                                   ontolex:LexicalConcept ;
                          ontolex:isConceptOf :Grouting_refusal ;
                          rdfs:comment "Point at which grout intake drops to an acceptably low rate at the target pressure"@en ,
                                       "Берілген қысымда (бас тарту қысымында) топыраққа сіңірілетін ерітінді шығынының ең аз рұқсат етілген шамаға дейін төмендеуі."@kz ,
                                       "Снижение расхода раствора, поглощаемого грунтом, до минимально допустимой величины при заданном давлении (давлении отказа)"@ru ;
                          rdfs:isDefinedBy "СН РК 5.01-01-2013 Земляные сооружения, основания и фундаменты (Document_97057d47-3060-42cc-bc25-2af554423c81)" ;
                          rdfs:label "grouting refusal"@en ,
                                     "отказ при проведении цементации"@ru ,
                                     "цементтеу кезінде бас тарту"@kz .


###  http://ontogeo.kz/geont-kz#Grouting_refusal_LexicalEntry
