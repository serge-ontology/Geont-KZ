                                                   ontolex:MultiWordExpression ;
                                          ontolex:evokes :Stepincreasing_tamping_mode_Concept ;
                                          rdfs:label "step-increasing tamping mode"@en ,
                                                     "соққы жүктемесін қолдану режимінің жоғарылауы"@kz ,
                                                     "ступенчато-возрастающий режим приложения ударной нагрузки"@ru .


###  http://ontogeo.kz/geont-kz#Stiff_material
:Stiff_material rdf:type owl:NamedIndividual .


###  http://ontogeo.kz/geont-kz#Stiff_material_Concept
:Stiff_material_Concept rdf:type owl:NamedIndividual ,
                                 ontolex:LexicalConcept ;
                        ontolex:isConceptOf :Stiff_material ;
                        rdfs:comment "Natural or artificial coarse material (gravel, crushed stone, brick rubble) rammed into an excavation bottom"@en ,
                                     "Природный или искусственный материал в виде гравия, щебня, гравийно-галечниковой смеси, кирпичного бояи др., втрамбовываемый в дно котлована"@ru ,
                                     "Қиыршық тас, шағыл тас, қиыршық-малтатас қоспасы, кірпіш сынықтары және т.б. түріндегі, шұңқырдың түбіне тығыздалатын табиғи немесе жасанды материал."@kz ;
                        rdfs:isDefinedBy "СП РК 5.01-107-2013 Контроль несущей способности фундаментов (ФВК) по результатам вытрамбовывания их котлованов (Document_6df2c6f6-ffd9-43e9-9120-5084265388ff)" ;
                        rdfs:label "stiff material"@en ,
                                   "жесткий материал"@ru ,
                                   "қатты материал"@kz .


