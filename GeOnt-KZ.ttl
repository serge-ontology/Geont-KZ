:Underground_structure_Concept rdf:type owl:NamedIndividual ,
                                        ontolex:LexicalConcept ;
                               ontolex:isConceptOf :Underground_structure ;
                               rdfs:comment "Structure located wholly or partly below ground level"@en ,
                                            "Жер бетінің деңгейінен төмен орналасқан құрылыс немесе құрылыстың бөлігі."@kz ,
                                            "сооружение или часть сооружения, расположенная ниже уровня поверхности земли"@ru ;
                               rdfs:isDefinedBy "СН РК 2.03-01-2011 Здания и сооружения на подрабатываемых территориях и просадочных грунтах (Document_14719947-81c3-4bcd-917d-5b23915055e1)" ;
                               rdfs:label "underground structure"@en ,
                                          "жерасты құрылысы немесе құрылыстың жерасты бөлігі"@kz ,
                                          "подземное сооружение или подземная часть сооружения"@ru .


