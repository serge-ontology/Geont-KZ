                             ontolex:LexicalConcept ;
                    ontolex:isConceptOf :Soil_nails ;
                    rdfs:comment "Horizontally or obliquely installed, untensioned bars used to stabilise slopes and cuts"@en ,
                                 "Беткейлер мен беткейлердің тұрақтылығын қамтамасыз етуге арналған геотехникалық конструкция, қосымша кернеусіз көлденең немесе көлбеу орналасады"@kz ,
                                 "Геотехническая конструкция для обеспечения устойчивости откосов и склонов, устраиваемая горизонтально или наклонно без дополнительного натяжения"@ru ;
                    rdfs:isDefinedBy "НТП РК 08.05.1-2022 Проектирование оснований и фундаментов зданий и сооружений в сейсмических районах (Document_4a85e34a-20fa-49f7-bbc3-4aeca1ebd5d1)" ;
                    rdfs:label "soil nails"@en ,
                               "грунтовые нагели"@ru ,
                               "топырақ сына"@kz .


