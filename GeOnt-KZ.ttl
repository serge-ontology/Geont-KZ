                              ontolex:LexicalConcept ;
                     ontolex:isConceptOf :Drop_hammer ;
                     rdfs:comment "Falling mass in a hammer system delivering impact energy"@en ,
                                  "Конусты ілгерілету үшін қажетті энергияны беру мақсатында бірізді көтеріліп, жіберілетін соққы-қағу механизмінің бөлігі."@kz ,
                                  "Часть ударно-забивного механизма, который последовательно поднимается и отпускается для передачи энергии, необходимой для продвижения конуса"@ru ;
                     rdfs:isDefinedBy "СТ РК ISO 22476-2-2012 Геотехнические исследования и испытания. Полевые испытания. Часть 2. Динамическое зондирование (Document_203f9a0d-25a2-4a98-9e5f-141db75c24f7)" ;
                     rdfs:label "drop hammer"@en ,
                                "балға"@kz ,
                                "молот"@ru .


