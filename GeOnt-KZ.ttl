                            rdfs:label "panel overlap"@en ,
                                       "нахлестка"@ru ,
                                       "қабаттасу"@kz .


###  http://ontogeo.kz/geont-kz#Panel_trimming
:Panel_trimming rdf:type owl:NamedIndividual .


###  http://ontogeo.kz/geont-kz#Panel_trimming_Concept
:Panel_trimming_Concept rdf:type owl:NamedIndividual ,
                                 ontolex:LexicalConcept ;
                        ontolex:isConceptOf :Panel_trimming ;
                        rdfs:comment "Removal of excess or contaminated concrete from diaphragm-wall panel top"@en ,
                                     "Траншеяда бетондалатын қабырғалардың үстіңгі жағынан, жобалық кесу деңгейінен жоғары орналасқан ластанған, артық немесе стандартқа сәйкес келмейтін бетонды кетіру."@kz ,
                                     "Удаление загрязненного, лишнего или несоответствующего стандарту бетона с вершины стен, бетонируемых в траншее, выше проектного уровня отсечки"@ru ;
                        rdfs:isDefinedBy "СТ РК EN 1538-2012 Выполнение специальных геотехнических работ. Стены в грунте (Document_f7c53fbf-8948-4734-974c-d1fdf444001b)" ;
                        rdfs:label "panel trimming"@en ,
                                   "аяқтау"@kz ,
                                   "отделка"@ru .


