                              ontolex:LexicalConcept ;
                     ontolex:isConceptOf :Anchor_head ;
                     rdfs:comment "Component of a ground anchor that transfers tendon load to the bearing plate or structural member"@en ,
                                  "созылу элементінен тірек тақтасына немесе құрылыс құрылымына созылу күшін беретін жерге қосылған анкер бөлігі"@kz ,
                                  "часть заземленного анкера, передающая растягивающее усилие с растягивающего элемента на опорную плиту или строительную конструкцию"@ru ;
                     rdfs:isDefinedBy "СТ РК ЕN 1537-2011 Выполнение специальных геотехнических работ. Грунтовые анкеры (Document_86288b05-c9b3-406e-aa3f-86d5bdf17a4b)" ;
